@implements IDisposable
@inject LocalizationService Localizer

<MudNavMenu Class="nav-list mud-nav-list">
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SpaceDashboard">@Localizer["nav.start"]</MudNavLink>
    <MudNavLink Href="analysis" Icon="@Icons.Material.Filled.Search">@Localizer["nav.analysis"]</MudNavLink>
    <MudNavLink Href="household" Icon="@Icons.Material.Filled.Groups">@Localizer["nav.household"]</MudNavLink>
    <MudNavLink Href="housing" Icon="@Icons.Material.Filled.HomeWork">@Localizer["nav.housingTab"]</MudNavLink>
    <MudNavLink Href="transport" Icon="@Icons.Material.Filled.DirectionsCar">@Localizer["nav.transport"]</MudNavLink>
    <MudNavLink Href="expenses" Icon="@Icons.Material.Filled.ReceiptLong">@Localizer["nav.expenses"]</MudNavLink>
    <MudNavLink Href="credits" Icon="@Icons.Material.Filled.CreditCard">@Localizer["nav.credits"]</MudNavLink>
    <MudNavLink Href="savings" Icon="@Icons.Material.Filled.Savings">@Localizer["nav.savings"]</MudNavLink>
    <MudNavLink Href="import" Icon="@Icons.Material.Filled.UploadFile">@Localizer["nav.import"]</MudNavLink>
    <MudNavLink Href="settings" Icon="@Icons.Material.Filled.Settings">@Localizer["nav.settings"]</MudNavLink>
    <MudNavLink Href="help" Icon="@Icons.Material.Filled.Help">@Localizer["nav.help"]</MudNavLink>
</MudNavMenu>

@code {
    protected override void OnInitialized()
    {
        Localizer.Changed += HandleChanged;
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Localizer.Changed -= HandleChanged;
    }
}
