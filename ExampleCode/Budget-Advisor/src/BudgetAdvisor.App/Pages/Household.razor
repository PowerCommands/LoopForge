@page "/household"
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using System.Text.RegularExpressions
@implements IDisposable
@inject ApplicationState AppState
@inject IDialogService DialogService
@inject LocalizationService Localizer

<MudTabs Class="section-tabs" Rounded="true" SliderColor="Color.Primary" Elevation="0">
    <MudTabPanel Text="@Localizer["household.incomesTab"]" Icon="@Icons.Material.Filled.ReceiptLong">
        <section class="card-panel mt-4">
            <div class="section-title-row">
                <div></div>
                <label class="form-check-label d-flex align-items-center gap-2">
                    <InputCheckbox class="form-check-input mt-0" @bind-Value="showAllIncomes" />
                    <span>@Localizer["filter.showAllIncomes"]</span>
                </label>
            </div>
            <div class="form-grid mb-3">
                <div>
                    <label class="form-label">@Localizer["field.member"]</label>
                    <InputSelect class="form-select" @bind-Value="incomeMemberFilter">
                        <option value="">@Localizer["filter.allCategories"]</option>
                        <option value="@UnassignedMemberFilterValue">@Localizer["common.unknown"]</option>
                        @foreach (var member in IncomeMemberOptions)
                        {
                            <option value="@member.Id">@member.Name</option>
                        }
                    </InputSelect>
                </div>
                <div>
                    <label class="form-label">@Localizer["field.subcategory"]</label>
                    <InputSelect class="form-select" @bind-Value="incomeSubcategoryFilter">
                        <option value="">@Localizer["filter.allSubcategories"]</option>
                        @foreach (var subcategory in IncomeSubcategoryOptions)
                        {
                            <option value="@subcategory">@subcategory</option>
                        }
                    </InputSelect>
                </div>
                <div>
                    <label class="form-label">@Localizer["field.year"]</label>
                    <InputSelect class="form-select" @bind-Value="incomeYearFilter">
                        <option value="">@Localizer["filter.allCategories"]</option>
                        @foreach (var year in IncomeYearOptions)
                        {
                            <option value="@year">@year</option>
                        }
                    </InputSelect>
                </div>
                <div>
                    <label class="form-label">@Localizer["field.month"]</label>
                    <InputSelect class="form-select" @bind-Value="incomeMonthFilter">
                        <option value="">@Localizer["filter.allCategories"]</option>
                        @foreach (var month in IncomeMonthOptions)
                        {
                            <option value="@month">@Localizer[$"month.{month}"]</option>
                        }
                    </InputSelect>
                </div>
                <div>
                    <label class="form-label">@Localizer["field.amount"]</label>
                    <InputText class="form-control" @bind-Value="incomeAmountFilter" />
                </div>
            </div>
            <div class="table-responsive">
                <table class="table app-table">
                    <thead>
                        <tr>
                            <th>@Localizer["field.member"]</th>
                            <th>@Localizer["field.subcategory"]</th>
                            <th>@Localizer["field.year"]</th>
                            <th>@Localizer["field.month"]</th>
                            <th>@Localizer["field.amount"]</th>
                            <th>@Localizer["field.actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!IncomeEntries.Any())
                        {
                            <tr>
                                <td colspan="6" class="empty-state">@Localizer["table.noIncomeRows"]</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var income in IncomeEntries)
                            {
                                <tr>
                                    <td>@GetIncomeOwnerLabel(income)</td>
                                    <td>@GetIncomeTypeDisplay(income)</td>
                                    <td>@income.Year</td>
                                    <td>@Localizer[$"month.{income.Month}"]</td>
                                    <td class="income-amount-cell" @ondblclick="() => BeginEditIncomeAmount(income)">
                                        @if (editingIncomeId == income.Id)
                                        {
                                            <input @ref="editingIncomeAmountInput"
                                                   class="form-control form-control-sm income-amount-input"
                                                   value="@editingIncomeAmountText"
                                                   @oninput="HandleIncomeAmountInput"
                                                   @onkeydown="HandleIncomeAmountKeyDownAsync"
                                                   @onblur="HandleIncomeAmountBlurAsync" />
                                        }
                                        else
                                        {
                                            <span>@AppState.FormatCurrency(income.Amount)</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="button-row income-action-row">
                                            @foreach (var member in AppState.Data.Members.OrderBy(member => member.Name))
                                            {
                                                <button class="btn btn-outline-primary btn-sm member-initial-button"
                                                        title="@member.Name"
                                                        disabled="@(income.MemberId == member.Id)"
                                                        @onclick="() => HandleAssignIncomeMemberAsync(income, member.Id)">
                                                    @GetMemberInitials(member)
                                                </button>
                                            }
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => HandleDeleteIncomeAsync(income))" />
                                        </div>
                                    </td>
                                </tr>
                            }

                            <tr class="table-summary-row">
                                <td colspan="4"><strong>@($"{Localizer["table.sum"]}:")</strong></td>
                                <td><strong>@AppState.FormatCurrency(TotalIncomeAmount)</strong></td>
                                <td></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["household.salaryTab"]" Icon="@Icons.Material.Filled.Payments">
        <section class="card-panel">
            <h2>@Localizer["household.salaryTab"]</h2>
            <EditForm EditContext="salaryGenerationEditContext" OnValidSubmit="HandleGenerateSalaryAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="form-grid">
                    <div>
                        <label class="form-label">@Localizer["field.member"]</label>
                        <InputSelect class="form-select" @bind-Value="salaryGenerationForm.MemberId">
                            <option value="">@Localizer["field.selectMember"]</option>
                            @foreach (var member in AppState.Data.Members.OrderBy(member => member.Name))
                            {
                                <option value="@member.Id">@member.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => salaryGenerationForm.MemberId" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.amount"]</label>
                        <InputNumber class="form-control" @bind-Value="salaryGenerationForm.Amount" />
                        <ValidationMessage For="() => salaryGenerationForm.Amount" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.start"]</label>
                        <InputDate class="form-control" @bind-Value="salaryGenerationForm.StartDate" />
                        <ValidationMessage For="() => salaryGenerationForm.StartDate" />
                    </div>
                    @if (!salaryGenerationForm.IsYearlyIncome)
                    {
                        <div>
                            <label class="form-label">@Localizer["field.end"]</label>
                            <InputDate class="form-control" @bind-Value="salaryGenerationForm.EndDate" />
                            <ValidationMessage For="() => salaryGenerationForm.EndDate" />
                        </div>
                    }
                    <div class="d-flex align-items-center gap-2 pt-4">
                        <InputCheckbox class="form-check-input" @bind-Value="salaryGenerationForm.IsYearlyIncome" />
                        <label class="form-label mb-0">@Localizer["household.yearlyIncomeToggle"]</label>
                    </div>
                </div>
                <button class="btn btn-primary" disabled="@(!HasMembers)" type="submit">@Localizer["action.generateSalary"]</button>
            </EditForm>
        </section>
        <section class="card-panel mt-4">
            <h2>@Localizer["household.salaryPeriods"]</h2>
            @if (SalaryPeriods.Count == 0)
            {
                <p class="empty-state">@Localizer["household.noSalaryPeriods"]</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table app-table">
                        <thead>
                            <tr>
                                <th>@Localizer["field.member"]</th>
                                <th>@Localizer["household.monthlySalary"]</th>
                                <th>@Localizer["field.start"]</th>
                                <th>@Localizer["field.end"]</th>
                                <th>@Localizer["field.actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var salaryPeriod in SalaryPeriods)
                            {
                                <tr>
                                    <td>@salaryPeriod.MemberName</td>
                                    <td>@AppState.FormatCurrency(salaryPeriod.MonthlyAmount)</td>
                                    <td>@FormatYearMonth(salaryPeriod.StartYear, salaryPeriod.StartMonth)</td>
                                    <td>@FormatYearMonth(salaryPeriod.EndYear, salaryPeriod.EndMonth)</td>
                                    <td>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="@(() => HandleDeleteSalaryPeriodAsync(salaryPeriod))" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["household.otherIncomeTab"]" Icon="@Icons.Material.Filled.AddCard">
        <section class="card-panel">
            <h2>@Localizer["household.otherIncomeTab"]</h2>
            <EditForm EditContext="oneTimeIncomeEditContext" OnValidSubmit="HandleAddOneTimeIncomeAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="form-grid">
                    <div>
                        <label class="form-label">@Localizer["field.member"]</label>
                        <InputSelect class="form-select" @bind-Value="oneTimeIncomeForm.MemberId">
                            <option value="">@Localizer["field.selectMember"]</option>
                            @foreach (var member in AppState.Data.Members.OrderBy(member => member.Name))
                            {
                                <option value="@member.Id">@member.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => oneTimeIncomeForm.MemberId" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.amount"]</label>
                        <InputNumber class="form-control" @bind-Value="oneTimeIncomeForm.Amount" />
                        <ValidationMessage For="() => oneTimeIncomeForm.Amount" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.date"]</label>
                        <InputDate class="form-control" @bind-Value="oneTimeIncomeForm.Date" />
                        <ValidationMessage For="() => oneTimeIncomeForm.Date" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.subcategory"]</label>
                        <InputText class="form-control" @bind-Value="oneTimeIncomeForm.Type" list="one-time-income-types" />
                        <datalist id="one-time-income-types">
                            @foreach (var incomeType in GetIncomeTypeSuggestions())
                            {
                                <option value="@incomeType"></option>
                            }
                        </datalist>
                        <ValidationMessage For="() => oneTimeIncomeForm.Type" />
                    </div>
                </div>
                <button class="btn btn-primary" disabled="@(!HasMembers)" type="submit">@Localizer["action.addIncome"]</button>
            </EditForm>
        </section>
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["household.membersTab"]" Icon="@Icons.Material.Filled.Groups">
        <div class="stack-grid">
            <section class="card-panel">
                <h2>@Localizer["household.addMember"]</h2>
                <EditForm EditContext="memberEditContext" OnValidSubmit="HandleAddMemberAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="form-grid">
                        <div>
                            <label class="form-label">@Localizer["field.name"]</label>
                            <InputText class="form-control" @bind-Value="memberForm.Name" />
                            <ValidationMessage For="() => memberForm.Name" />
                        </div>
                        <div>
                            <label class="form-label">@Localizer["field.initials"]</label>
                            <InputText class="form-control text-uppercase" @bind-Value="memberForm.Initials" />
                            <ValidationMessage For="() => memberForm.Initials" />
                        </div>
                    </div>
                    <button class="btn btn-primary" type="submit">@Localizer["action.addMember"]</button>
                </EditForm>
            </section>

            <section class="card-panel">
                <h2>@Localizer["household.members"]</h2>
                @if (AppState.Data.Members.Count == 0)
                {
                    <p class="empty-state">@Localizer["household.noMembers"]</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table app-table">
                            <thead>
                                <tr>
                                    <th>@Localizer["field.name"]</th>
                                    <th>@Localizer["field.initial"]</th>
                                    <th>@Localizer["household.averageMonthlyIncome"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var member in AppState.Data.Members.OrderBy(member => member.Name))
                                {
                                    <tr>
                                        <td class="member-edit-cell" @ondblclick="() => BeginEditMember(member, MemberEditField.Name)">
                                            @if (editingMemberId == member.Id && editingMemberField == MemberEditField.Name)
                                            {
                                                <input @ref="editingMemberInput"
                                                       class="form-control form-control-sm member-edit-input"
                                                       value="@editingMemberText"
                                                       @oninput="HandleMemberInput"
                                                       @onkeydown="HandleMemberKeyDownAsync"
                                                       @onblur="HandleMemberBlurAsync" />
                                            }
                                            else
                                            {
                                                <span>@member.Name</span>
                                            }
                                        </td>
                                        <td class="member-edit-cell" @ondblclick="() => BeginEditMember(member, MemberEditField.Initials)">
                                            @if (editingMemberId == member.Id && editingMemberField == MemberEditField.Initials)
                                            {
                                                <input @ref="editingMemberInput"
                                                       class="form-control form-control-sm member-edit-input text-uppercase"
                                                       value="@editingMemberText"
                                                       @oninput="HandleMemberInput"
                                                       @onkeydown="HandleMemberKeyDownAsync"
                                                       @onblur="HandleMemberBlurAsync" />
                                            }
                                            else
                                            {
                                                <span>@GetMemberInitials(member)</span>
                                            }
                                        </td>
                                        <td>@AppState.FormatCurrency(GetAverageMonthlyIncome(member.Id))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>
    </MudTabPanel>

</MudTabs>

@code {
    private MemberFormModel memberForm = new();
    private EditContext memberEditContext = default!;
    private OneTimeIncomeFormModel oneTimeIncomeForm = new();
    private SalaryGenerationFormModel salaryGenerationForm = new();
    private EditContext oneTimeIncomeEditContext = default!;
    private EditContext salaryGenerationEditContext = default!;
    private bool showAllIncomes;
    private string incomeMemberFilter = string.Empty;
    private string incomeSubcategoryFilter = string.Empty;
    private string incomeYearFilter = string.Empty;
    private string incomeMonthFilter = string.Empty;
    private string incomeAmountFilter = string.Empty;
    private Guid? editingIncomeId;
    private string editingIncomeAmountText = string.Empty;
    private ElementReference editingIncomeAmountInput;
    private bool shouldFocusEditingIncomeAmount;
    private Guid? editingMemberId;
    private MemberEditField? editingMemberField;
    private string editingMemberText = string.Empty;
    private ElementReference editingMemberInput;
    private bool shouldFocusEditingMember;
    private const string UnassignedMemberFilterValue = "__unassigned__";

    private bool HasMembers => AppState.Data.Members.Count > 0;

    private IReadOnlyList<SalaryIncomePeriodDisplay> SalaryPeriods => AppState.GetSalaryIncomePeriods();

    private IReadOnlyList<IncomeEntry> IncomeEntries =>
        GetFilteredIncomeEntries()
            .Where(record =>
                showAllIncomes ||
                (record.Year == DateTime.Today.Year && record.Month == DateTime.Today.Month))
            .OrderByDescending(record => record.Year)
            .ThenByDescending(record => record.Month)
            .ThenBy(record => GetIncomeOwnerLabel(record))
            .ThenBy(record => GetIncomeTypeDisplay(record))
            .ToList();

    private decimal TotalIncomeAmount => IncomeEntries.Sum(record => record.Amount);

    private IReadOnlyList<HouseholdMember> IncomeMemberOptions =>
        AppState.Data.Members
            .OrderBy(member => member.Name)
            .ToList();

    private IReadOnlyList<string> IncomeSubcategoryOptions =>
        FilterIncomeEntries(skipSubcategoryFilter: true)
            .Select(GetIncomeSubcategoryLabel)
            .Where(type => !string.IsNullOrWhiteSpace(type))
            .Distinct(StringComparer.CurrentCultureIgnoreCase)
            .OrderBy(type => type, StringComparer.CurrentCultureIgnoreCase)
            .ToList();

    private IReadOnlyList<int> IncomeYearOptions =>
        FilterIncomeEntries(skipYearFilter: true)
            .Select(entry => entry.Year)
            .Distinct()
            .OrderByDescending(year => year)
            .ToList();

    private IReadOnlyList<int> IncomeMonthOptions =>
        FilterIncomeEntries(skipMonthFilter: true)
            .Select(entry => entry.Month)
            .Distinct()
            .OrderBy(month => month)
            .ToList();

    protected override void OnInitialized()
    {
        AppState.Changed += HandleChanged;
        Localizer.Changed += HandleChanged;
        ResetIncomeForms();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldFocusEditingIncomeAmount)
        {
            shouldFocusEditingIncomeAmount = false;
            await editingIncomeAmountInput.FocusAsync();
            return;
        }

        if (shouldFocusEditingMember)
        {
            shouldFocusEditingMember = false;
            await editingMemberInput.FocusAsync();
        }
    }

    private async Task HandleAddMemberAsync()
    {
        memberForm.Initials = NormalizeInitialsInput(memberForm.Initials);
        await AppState.AddMemberAsync(memberForm.Name, memberForm.Initials);
        memberForm = new MemberFormModel();
        memberEditContext = new EditContext(memberForm);
    }

    private async Task HandleAddOneTimeIncomeAsync()
    {
        var date = DateOnly.FromDateTime(oneTimeIncomeForm.Date!.Value);
        await AppState.AddOneTimeIncomeAsync(oneTimeIncomeForm.MemberId!.Value, oneTimeIncomeForm.Amount, date.Year, date.Month, oneTimeIncomeForm.Type, transactionDate: date);
        oneTimeIncomeForm = new OneTimeIncomeFormModel();
        ResetIncomeForms();
    }

    private async Task HandleGenerateSalaryAsync()
    {
        var startDate = DateOnly.FromDateTime(salaryGenerationForm.StartDate!.Value);
        if (salaryGenerationForm.IsYearlyIncome)
        {
            await AppState.AddYearlyIncomeAsync(salaryGenerationForm.MemberId!.Value, salaryGenerationForm.Amount, startDate.Year, Localizer["incomeType.Salary"]);
        }
        else
        {
            var endDate = DateOnly.FromDateTime(salaryGenerationForm.EndDate!.Value);
            await AppState.AddMonthlySalaryAsync(salaryGenerationForm.MemberId!.Value, salaryGenerationForm.Amount, startDate.Year, startDate.Month, endDate.Year, endDate.Month);
        }

        salaryGenerationForm = new SalaryGenerationFormModel();
        ResetIncomeForms();
    }

    private async Task HandleDeleteIncomeAsync(IncomeEntry income)
    {
        if (income.SeriesId.HasValue)
        {
            var seriesParameters = new DialogParameters<SeriesDeleteDialog>
            {
                { dialog => dialog.Title, Localizer["dialog.deleteSeriesTitle"] },
                { dialog => dialog.Message, Localizer["household.deleteIncomeSeriesMessage"] },
                { dialog => dialog.SingleText, Localizer["action.deleteOne"] },
                { dialog => dialog.SeriesText, Localizer["action.deleteSeries"] },
                { dialog => dialog.CancelText, Localizer["action.cancel"] }
            };

            var seriesDialog = await DialogService.ShowAsync<SeriesDeleteDialog>(Localizer["dialog.deleteSeriesTitle"], seriesParameters);
            if (seriesDialog is null)
            {
                return;
            }

            var seriesResult = await seriesDialog.Result;
            if (seriesResult?.Canceled ?? true)
            {
                return;
            }

            var removeSeries = string.Equals(seriesResult.Data?.ToString(), "series", StringComparison.OrdinalIgnoreCase);
            await AppState.RemoveIncomeAsync(income.Id, removeSeries);
            return;
        }

        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, Localizer["household.deleteIncomeMessage"] },
            { dialog => dialog.ConfirmText, Localizer["action.delete"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveIncomeAsync(income.Id, false);
    }

    private async Task HandleDeleteSalaryPeriodAsync(SalaryIncomePeriodDisplay salaryPeriod)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, Localizer["household.deleteSalaryPeriodMessage"] },
            { dialog => dialog.ConfirmText, Localizer["action.deleteSeries"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveSalaryIncomePeriodAsync(salaryPeriod.Id);
    }

    private async Task HandleAssignIncomeMemberAsync(IncomeEntry income, Guid memberId)
    {
        await AppState.UpdateIncomeMemberAsync(income.Id, memberId);
    }

    private void BeginEditIncomeAmount(IncomeEntry income)
    {
        editingIncomeId = income.Id;
        editingIncomeAmountText = income.Amount.ToString("0.##", CultureInfo.CurrentCulture);
        shouldFocusEditingIncomeAmount = true;
    }

    private async Task HandleIncomeAmountKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or "NumpadEnter" or "Tab")
        {
            await SaveEditedIncomeAmountAsync();
            return;
        }

        if (args.Key == "Escape")
        {
            CancelEditedIncomeAmount();
        }
    }

    private async Task HandleIncomeAmountBlurAsync(FocusEventArgs _)
    {
        await SaveEditedIncomeAmountAsync();
    }

    private void HandleIncomeAmountInput(ChangeEventArgs args)
    {
        editingIncomeAmountText = args.Value?.ToString() ?? string.Empty;
    }

    private async Task SaveEditedIncomeAmountAsync()
    {
        if (!editingIncomeId.HasValue)
        {
            return;
        }

        var income = AppState.Data.IncomeRecords.FirstOrDefault(entry => entry.Id == editingIncomeId.Value);
        if (income is null)
        {
            CancelEditedIncomeAmount();
            return;
        }

        if (!TryParseIncomeAmount(editingIncomeAmountText, out var amount) || amount <= 0m)
        {
            CancelEditedIncomeAmount();
            return;
        }

        await AppState.UpdateIncomeAmountAsync(income.Id, amount);
        CancelEditedIncomeAmount();
    }

    private void CancelEditedIncomeAmount()
    {
        editingIncomeId = null;
        editingIncomeAmountText = string.Empty;
        shouldFocusEditingIncomeAmount = false;
    }

    private void BeginEditMember(HouseholdMember member, MemberEditField field)
    {
        editingMemberId = member.Id;
        editingMemberField = field;
        editingMemberText = field == MemberEditField.Name
            ? member.Name
            : GetMemberInitials(member);
        shouldFocusEditingMember = true;
    }

    private void HandleMemberInput(ChangeEventArgs args)
    {
        editingMemberText = args.Value?.ToString() ?? string.Empty;
    }

    private async Task HandleMemberKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or "NumpadEnter" or "Tab")
        {
            await SaveEditedMemberAsync();
            return;
        }

        if (args.Key == "Escape")
        {
            CancelEditedMember();
        }
    }

    private async Task HandleMemberBlurAsync(FocusEventArgs _)
    {
        await SaveEditedMemberAsync();
    }

    private async Task SaveEditedMemberAsync()
    {
        if (!editingMemberId.HasValue || !editingMemberField.HasValue)
        {
            return;
        }

        var member = AppState.Data.Members.FirstOrDefault(item => item.Id == editingMemberId.Value);
        if (member is null)
        {
            CancelEditedMember();
            return;
        }

        var name = member.Name;
        var initials = GetMemberInitials(member);

        if (editingMemberField == MemberEditField.Name)
        {
            name = editingMemberText.Trim();
        }
        else
        {
            initials = NormalizeInitialsInput(editingMemberText);
        }

        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(initials))
        {
            CancelEditedMember();
            return;
        }

        await AppState.UpdateMemberAsync(member.Id, name, initials);
        CancelEditedMember();
    }

    private void CancelEditedMember()
    {
        editingMemberId = null;
        editingMemberField = null;
        editingMemberText = string.Empty;
        shouldFocusEditingMember = false;
    }

    private static bool TryParseIncomeAmount(string value, out decimal amount)
    {
        if (decimal.TryParse(value, NumberStyles.Number, CultureInfo.CurrentCulture, out amount))
        {
            return true;
        }

        return decimal.TryParse(value, NumberStyles.Number, CultureInfo.InvariantCulture, out amount);
    }

    private void ResetIncomeForms()
    {
        var today = DateTime.Today;

        memberEditContext = new EditContext(memberForm);
        oneTimeIncomeForm.Date = today;
        oneTimeIncomeForm.Type = Localizer["incomeType.Salary"];
        salaryGenerationForm.StartDate = today;
        salaryGenerationForm.EndDate = today;

        oneTimeIncomeEditContext = new EditContext(oneTimeIncomeForm);
        salaryGenerationEditContext = new EditContext(salaryGenerationForm);
    }

    private string GetMemberName(Guid memberId) =>
        AppState.Data.Members.FirstOrDefault(member => member.Id == memberId)?.Name ?? Localizer["common.unknown"];

    private decimal GetAverageMonthlyIncome(Guid memberId)
    {
        var memberIncomes = AppState.Data.IncomeRecords
            .Where(entry => entry.MemberId == memberId)
            .ToList();

        if (memberIncomes.Count == 0)
        {
            return 0m;
        }

        var monthCount = memberIncomes
            .Select(entry => (entry.Year, entry.Month))
            .Distinct()
            .Count();

        return monthCount == 0
            ? 0m
            : memberIncomes.Sum(entry => entry.Amount) / monthCount;
    }

    private string GetMemberInitials(HouseholdMember member)
    {
        var initials = NormalizeInitialsInput(member.Initials);
        if (!string.IsNullOrWhiteSpace(initials))
        {
            return initials;
        }

        var lettersOnly = new string(member.Name.Where(char.IsLetter).ToArray());
        if (string.IsNullOrWhiteSpace(lettersOnly))
        {
            return "???";
        }

        return lettersOnly.Length <= 3
            ? lettersOnly.ToUpperInvariant()
            : lettersOnly[..3].ToUpperInvariant();
    }

    private string GetIncomeOwnerLabel(IncomeEntry income) =>
        income.SavingsAccountId.HasValue && !string.IsNullOrWhiteSpace(income.Metadata)
            ? income.Metadata
            : GetMemberName(income.MemberId);

    private string GetIncomeTypeDisplay(IncomeEntry income)
    {
        var typeLabel = AppState.GetIncomeTypeDisplay(income.Type);

        return string.IsNullOrWhiteSpace(income.Metadata) ? typeLabel : $"{income.Metadata} - {typeLabel}";
    }

    private string GetIncomeSubcategoryLabel(IncomeEntry income) =>
        AppState.GetIncomeTypeDisplay(income.Type);

    private string FormatYearMonth(int year, int month) => $"{year}-{month:00}";

    private IReadOnlyList<string> GetIncomeTypeSuggestions() =>
        AppState.GetIncomeTypeSuggestions();

    private IReadOnlyList<IncomeEntry> GetFilteredIncomeEntries() =>
        FilterIncomeEntries().ToList();

    private IEnumerable<IncomeEntry> FilterIncomeEntries(
        bool skipMemberFilter = false,
        bool skipSubcategoryFilter = false,
        bool skipYearFilter = false,
        bool skipMonthFilter = false,
        bool skipAmountFilter = false)
    {
        var query = AppState.Data.IncomeRecords.AsEnumerable();

        if (!skipMemberFilter && !string.IsNullOrWhiteSpace(incomeMemberFilter))
        {
            query = string.Equals(incomeMemberFilter, UnassignedMemberFilterValue, StringComparison.Ordinal)
                ? query.Where(entry => entry.MemberId == Guid.Empty)
                : Guid.TryParse(incomeMemberFilter, out var memberId)
                    ? query.Where(entry => entry.MemberId == memberId)
                    : query;
        }

        if (!skipSubcategoryFilter && !string.IsNullOrWhiteSpace(incomeSubcategoryFilter))
        {
            query = query.Where(entry => string.Equals(GetIncomeSubcategoryLabel(entry), incomeSubcategoryFilter, StringComparison.CurrentCultureIgnoreCase));
        }

        if (!skipYearFilter && int.TryParse(incomeYearFilter, out var year))
        {
            query = query.Where(entry => entry.Year == year);
        }

        if (!skipMonthFilter && int.TryParse(incomeMonthFilter, out var month))
        {
            query = query.Where(entry => entry.Month == month);
        }

        if (!skipAmountFilter &&
            !string.IsNullOrWhiteSpace(incomeAmountFilter) &&
            TryParseIncomeAmount(incomeAmountFilter, out var amount))
        {
            query = query.Where(entry => entry.Amount == amount);
        }

        return query;
    }

    private static string NormalizeInitialsInput(string value)
    {
        var lettersOnly = Regex.Replace(value ?? string.Empty, "[^\\p{L}]", string.Empty);
        return lettersOnly.Length <= 3
            ? lettersOnly.ToUpperInvariant()
            : lettersOnly[..3].ToUpperInvariant();
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AppState.Changed -= HandleChanged;
        Localizer.Changed -= HandleChanged;
    }

    private sealed class MemberFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(100, ErrorMessage = "Name must be 100 characters or fewer.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Initials are required.")]
        [RegularExpression(@"^\p{L}{1,3}$", ErrorMessage = "Initials must be 1-3 letters.")]
        public string Initials { get; set; } = string.Empty;
    }

    private sealed class OneTimeIncomeFormModel
    {
        [Required(ErrorMessage = "Member is required.")]
        public Guid? MemberId { get; set; }

        [Range(typeof(decimal), "0.01", "999999999", ErrorMessage = "Amount must be greater than zero.")]
        public decimal Amount { get; set; }

        [Required(ErrorMessage = "Date is required.")]
        public DateTime? Date { get; set; }

        [Required(ErrorMessage = "Subcategory is required.")]
        [StringLength(60, ErrorMessage = "Subcategory must be 60 characters or fewer.")]
        public string Type { get; set; } = string.Empty;
    }

    private sealed class SalaryGenerationFormModel : IValidatableObject
    {
        [Required(ErrorMessage = "Member is required.")]
        public Guid? MemberId { get; set; }

        [Range(typeof(decimal), "0.01", "999999999", ErrorMessage = "Amount must be greater than zero.")]
        public decimal Amount { get; set; }

        [Required(ErrorMessage = "Start date is required.")]
        public DateTime? StartDate { get; set; }

        public DateTime? EndDate { get; set; }

        public bool IsYearlyIncome { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (IsYearlyIncome)
            {
                yield break;
            }

            if (!EndDate.HasValue)
            {
                yield return new ValidationResult("End date is required.", [nameof(EndDate)]);
                yield break;
            }

            if (StartDate.HasValue &&
                EndDate.HasValue &&
                DateOnly.FromDateTime(EndDate.Value) < DateOnly.FromDateTime(StartDate.Value))
            {
                yield return new ValidationResult("End period must be the same as or later than the start period.", [nameof(EndDate)]);
            }
        }
    }

