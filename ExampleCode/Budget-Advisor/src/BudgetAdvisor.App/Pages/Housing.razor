@page "/housing"
@using System.ComponentModel.DataAnnotations
@implements IDisposable
@inject ApplicationState AppState
@inject IDialogService DialogService
@inject LocalizationService Localizer

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="status-banner">@statusMessage</div>
}

<MudTabs Class="section-tabs" Rounded="true" SliderColor="Color.Primary" Elevation="0">
    <MudTabPanel Text="@Localizer["housing.costsTab"]" Icon="@Icons.Material.Filled.ReceiptLong">
        <ExpenseRecordsTable Scope="ExpenseQueryScope.Housing"
                             ShowTitle="false"
                             DefaultToCurrentMonth="true"
                             ShowAllCostsToggle="true"
                             ShowCategoryFilter="false"
                             UseScopedDateRangeForShowAllCosts="true"
                             IncludeAllCosts="@showAllHousingCosts"
                             IncludeAllCostsChanged="HandleShowAllHousingCostsChanged"
                             OnDelete="HandleDeleteExpenseAsync" />
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["housing.oneTimeCost"]" Icon="@Icons.Material.Filled.AddCard">
        <section class="card-panel">
            <h2>@Localizer["housing.oneTimeCost"]</h2>
            <EditForm EditContext="costEditContext" OnValidSubmit="HandleAddCostAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="form-grid">
                    <div>
                        <label class="form-label">@Localizer["field.description"]</label>
                        <InputText class="form-control" @bind-Value="costForm.Description" />
                        <ValidationMessage For="() => costForm.Description" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.subcategory"]</label>
                        <InputText class="form-control" @bind-Value="costForm.Subcategory" list="housing-cost-subcategories" />
                        <datalist id="housing-cost-subcategories">
                            @foreach (var subcategory in GetSubcategorySuggestions())
                            {
                                <option value="@subcategory"></option>
                            }
                        </datalist>
                        <ValidationMessage For="() => costForm.Subcategory" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.amount"]</label>
                        <InputNumber class="form-control" @bind-Value="costForm.Amount" />
                        <ValidationMessage For="() => costForm.Amount" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.date"]</label>
                        <InputDate class="form-control" @bind-Value="costForm.Date" />
                        <ValidationMessage For="() => costForm.Date" />
                    </div>
                </div>
                <button class="btn btn-primary" type="submit">@Localizer["action.addHousingCost"]</button>
            </EditForm>
        </section>
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["housing.recurringCostsTab"]" Icon="@Icons.Material.Filled.Autorenew">
        <section class="card-panel">
            <h2>@Localizer["housing.series"]</h2>
            <EditForm EditContext="definitionEditContext" OnValidSubmit="HandleAddDefinitionAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="form-grid">
                    <div>
                        <label class="form-label">@Localizer["field.description"]</label>
                        <InputText class="form-control" @bind-Value="definitionForm.Description" />
                        <ValidationMessage For="() => definitionForm.Description" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.subcategory"]</label>
                        <InputText class="form-control" @bind-Value="definitionForm.Subcategory" list="housing-definition-subcategories" />
                        <datalist id="housing-definition-subcategories">
                            @foreach (var subcategory in GetSubcategorySuggestions())
                            {
                                <option value="@subcategory"></option>
                            }
                        </datalist>
                        <ValidationMessage For="() => definitionForm.Subcategory" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.amount"]</label>
                        <InputNumber class="form-control" @bind-Value="definitionForm.Amount" />
                        <ValidationMessage For="() => definitionForm.Amount" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.intervalMonths"]</label>
                        <InputNumber class="form-control" @bind-Value="definitionForm.IntervalMonths" />
                        <ValidationMessage For="() => definitionForm.IntervalMonths" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.start"]</label>
                        <InputDate class="form-control" @bind-Value="definitionForm.StartDate" />
                        <ValidationMessage For="() => definitionForm.StartDate" />
                    </div>
                    <div>
                        <label class="form-label">@Localizer["field.end"]</label>
                        <InputDate class="form-control" @bind-Value="definitionForm.EndDate" />
                        <ValidationMessage For="() => definitionForm.EndDate" />
                    </div>
                </div>
                <button class="btn btn-primary" type="submit">@Localizer["action.addHousingDefinition"]</button>
            </EditForm>
        </section>

        <section class="card-panel mt-4">
            <h2>@Localizer["housing.definitions"]</h2>
            <div class="table-responsive">
                <table class="table app-table">
                    <thead>
                        <tr>
                            <th>@Localizer["field.description"]</th>
                            <th>@Localizer["field.subcategory"]</th>
                            <th>@Localizer["field.amount"]</th>
                            <th>@Localizer["field.interval"]</th>
                            <th>@Localizer["field.start"]</th>
                            <th>@Localizer["field.end"]</th>
                            <th>
                                <div class="table-actions-header">
                                    <span>@Localizer["field.actions"]</span>
                                    <button class="btn btn-outline-secondary btn-sm"
                                            @onclick="HandleArchiveExpiredDefinitionsAsync"
                                            title="@Localizer["action.archiveAll"]"
                                            aria-label="@Localizer["action.archiveAll"]"
                                            disabled="@(!HasExpiredDefinitions())">🗄️</button>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var definition in HousingDefinitions)
                        {
                            <tr>
                                <td>@definition.Description</td>
                                <td>@definition.Subcategory</td>
                                <td>@AppState.FormatCurrency(definition.Amount)</td>
                                <td>@GetIntervalLabel(definition.IntervalMonths)</td>
                                <td>@GetMonthYearLabel(definition.StartYear, definition.StartMonth)</td>
                                <td>@GetMonthYearLabel(definition.EndYear, definition.EndMonth)</td>
                                <td>
                                    <div class="button-row">
                                        <button class="btn btn-outline-secondary btn-sm"
                                                @onclick="() => HandleRenewDefinition(definition)"
                                                title="@Localizer["action.renew"]"
                                                aria-label="@Localizer["action.renew"]">♻️</button>
                                        <button class="btn btn-outline-secondary btn-sm"
                                                @onclick="() => HandleArchiveDefinitionAsync(definition)"
                                                title="@Localizer["action.archive"]"
                                                aria-label="@Localizer["action.archive"]">🗄️</button>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="@(() => HandleDeleteDefinitionAsync(definition))" />
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["housing.loansTab"]" Icon="@Icons.Material.Filled.AccountBalance">
        @if (HousingLoans.Any())
        {
            <section class="card-panel">
                <h2>@Localizer["start.keyMetrics"]</h2>
                <div class="stats-grid">
                    <div class="stat-card"><span>@Localizer["housing.currentAmortization"]</span><strong>@AppState.FormatCurrency(TotalHousingLoanAmortization)</strong></div>
                    <div class="stat-card"><span>@Localizer["housing.remainingDebt"]</span><strong>@AppState.FormatCurrency(TotalHousingLoanRemainingDebt)</strong></div>
                </div>
            </section>
        }

        <div class="stack-grid two-up mt-4">
            <section class="card-panel">
                <h2>@Localizer["housing.homeResidence"]</h2>
                <EditForm EditContext="homeResidenceEditContext" OnValidSubmit="HandleSaveHomeResidenceAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="form-grid">
                        <div>
                            <label class="form-label">@Localizer["housing.residenceType"]</label>
                            <InputSelect class="form-select" @bind-Value="homeResidenceForm.ResidenceType">
                                @foreach (var option in ResidenceTypeOptions)
                                {
                                    <option value="@option.Type">@Localizer[option.LabelKey]</option>
                                }
                            </InputSelect>
                        </div>
                        @if (ShowsOwnedResidenceFields)
                        {
                            <div>
                                <label class="form-label">@Localizer["housing.purchaseYear"]</label>
                                <InputNumber class="form-control" @bind-Value="homeResidenceForm.PurchaseYear" />
                                <ValidationMessage For="() => homeResidenceForm.PurchaseYear" />
                            </div>
                            <div>
                                <label class="form-label">@Localizer["housing.purchasePrice"]</label>
                                <InputNumber class="form-control" @bind-Value="homeResidenceForm.PurchasePrice" />
                                <ValidationMessage For="() => homeResidenceForm.PurchasePrice" />
                            </div>
                            <div>
                                <label class="form-label">@Localizer["housing.currentMarketValue"]</label>
                                <InputNumber class="form-control" @bind-Value="homeResidenceForm.CurrentMarketValue" />
                                <ValidationMessage For="() => homeResidenceForm.CurrentMarketValue" />
                            </div>
                        }
                    </div>
                    <button class="btn btn-primary" type="submit">@Localizer["action.save"]</button>
                </EditForm>
            </section>

            <section class="card-panel">
                <h2>@Localizer["housing.createLoan"]</h2>
                <EditForm EditContext="loanEditContext" OnValidSubmit="HandleAddLoanAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="form-grid">
                        <div>
                            <label class="form-label">@Localizer["field.name"]</label>
                            <InputText class="form-control" @bind-Value="loanForm.Name" />
                            <ValidationMessage For="() => loanForm.Name" />
                        </div>
                        <div>
                            <label class="form-label">@Localizer["housing.lender"]</label>
                            <InputText class="form-control" @bind-Value="loanForm.Lender" />
                            <ValidationMessage For="() => loanForm.Lender" />
                        </div>
                        <div>
                            <label class="form-label">@Localizer["housing.loanStartDate"]</label>
                            <InputDate class="form-control" @bind-Value="loanForm.LoanStartDate" />
                            <ValidationMessage For="() => loanForm.LoanStartDate" />
                        </div>
                        <div>
                            <label class="form-label">@Localizer["housing.initialLoanAmount"]</label>
                            <InputNumber class="form-control" @bind-Value="loanForm.InitialLoanAmount" />
                            <ValidationMessage For="() => loanForm.InitialLoanAmount" />
                        </div>
                        <div>
                            <label class="form-label">@Localizer["housing.remainingDebt"]</label>
                            <InputNumber class="form-control" @bind-Value="loanForm.RemainingDebt" />
                            <ValidationMessage For="() => loanForm.RemainingDebt" />
                        </div>
                    </div>
                    <button class="btn btn-primary" type="submit">@Localizer["action.addLoan"]</button>
                </EditForm>
            </section>
        </div>

        @if (!HousingLoans.Any())
        {
            <section class="card-panel mt-4">
                <p class="empty-state mb-0">@Localizer["housing.noLoans"]</p>
            </section>
        }
        else
        {
            <section class="card-panel mt-4">
                <div class="table-responsive">
                    <table class="table app-table compact-overview-table">
                        <thead>
                            <tr>
                                <th class="expander-column"></th>
                                <th>@Localizer["field.name"]</th>
                                <th>@Localizer["housing.lender"]</th>
                                <th>@Localizer["loans.bindingPeriod"]</th>
                                <th>@Localizer["field.status"]</th>
                                <th>@Localizer["table.interest"]</th>
                                <th>@Localizer["housing.currentAmortization"]</th>
                                <th>@Localizer["housing.remainingDebt"]</th>
                                <th>@Localizer["field.actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var loan in HousingLoans)
                            {
                                <tr>
                                    <td class="expander-column">
                                        <MudIconButton Icon="@(IsLoanExpanded(loan.Id) ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => ToggleLoanDetails(loan.Id))" />
                                    </td>
                                    <td>@loan.Name</td>
                                    <td>@loan.Lender</td>
                                    <td>@GetActiveBindingPeriodDisplay(loan.Id)</td>
                                    <td>@(HasActiveBindingPeriod(loan.Id) ? "✔️" : "✖️")</td>
                                    <td>@GetActiveBindingRateDisplay(loan.Id)</td>
                                    <td>@GetActiveAmortizationDisplay(loan.Id)</td>
                                    <td>@AppState.FormatCurrency(AppState.GetLoanCurrentBalance(loan.Id))</td>
                                    <td>
                                        <div class="button-row">
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => HandleBackfillLoanAmortizationAsync(loan.Id)">@Localizer["loans.backfillAmortization"]</button>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => HandleDeleteLoanAsync(loan))" />
                                        </div>
                                    </td>
                                </tr>
                                @if (IsLoanExpanded(loan.Id))
                                {
                                    <tr class="row-detail">
                                        <td colspan="9">
                                            <div class="inline-detail-shell">
                                                <div class="stack-grid two-up mt-4">
                                                    <section class="card-panel">
                                                        <div class="section-title-row">
                                                            <h3>@Localizer["housing.interestBindingPeriods"]</h3>
                                                            <label class="form-check-label d-flex align-items-center gap-2">
                                                                <InputCheckbox class="form-check-input mt-0" @bind-Value="showAllHousingBindingPeriods" />
                                                                <span>@Localizer["filter.showAll"]</span>
                                                            </label>
                                                        </div>
                                                        <EditForm EditContext="GetBindingPeriodEditContext(loan.Id)" OnValidSubmit="@(() => HandleAddBindingPeriodAsync(loan.Id))">
                                                            <DataAnnotationsValidator />
                                                            <ValidationSummary />
                                                            <div class="form-grid">
                                                                <div>
                                                                    <label class="form-label">@Localizer["field.start"]</label>
                                                                    <InputDate class="form-control" @bind-Value="GetBindingPeriodForm(loan.Id).StartDate" />
                                                                    <ValidationMessage For="@(() => GetBindingPeriodForm(loan.Id).StartDate)" />
                                                                </div>
                                                                <div>
                                                                    <label class="form-label">@Localizer["field.end"]</label>
                                                                    <InputDate class="form-control" @bind-Value="GetBindingPeriodForm(loan.Id).EndDate" />
                                                                    <ValidationMessage For="@(() => GetBindingPeriodForm(loan.Id).EndDate)" />
                                                                </div>
                                                                <div>
                                                                    <label class="form-label">@Localizer["housing.interestRate"]</label>
                                                                    <InputNumber class="form-control" @bind-Value="GetBindingPeriodForm(loan.Id).InterestRate" />
                                                                    <ValidationMessage For="@(() => GetBindingPeriodForm(loan.Id).InterestRate)" />
                                                                </div>
                                                                <div>
                                                                    <label class="form-label">@Localizer["housing.monthlyAmortizationAmount"]</label>
                                                                    <InputNumber class="form-control" @bind-Value="GetBindingPeriodForm(loan.Id).MonthlyAmortization" />
                                                                    <ValidationMessage For="@(() => GetBindingPeriodForm(loan.Id).MonthlyAmortization)" />
                                                                </div>
                                                            </div>
                                                            <button class="btn btn-primary" type="submit">@Localizer["housing.createBindingPeriod"]</button>
                                                        </EditForm>

                                                        <div class="table-responsive mt-4">
                                                            <table class="table app-table">
                                                                <thead>
                                                                    <tr>
                                                                        <th>@Localizer["field.start"]</th>
                                                                        <th>@Localizer["field.end"]</th>
                                                                        <th>@Localizer["housing.interestRate"]</th>
                                                                        <th>@Localizer["housing.monthlyAmortizationAmount"]</th>
                                                                        <th>@Localizer["field.actions"]</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    @if (!GetVisibleLoanInterestBindingPeriods(loan.Id).Any())
                                                                    {
                                                                        <tr>
                                                                            <td colspan="5" class="empty-state">@Localizer["housing.noBindingPeriods"]</td>
                                                                        </tr>
                                                                    }
                                                                    else
                                                                    {
                                                                        @foreach (var period in GetVisibleLoanInterestBindingPeriods(loan.Id))
                                                                        {
                                                                            <tr>
                                                                                <td>@FormatDate(period.StartMonth)</td>
                                                                                <td>@FormatDate(period.EndMonth)</td>
                                                                                <td>@FormatInterestRate(period.InterestRate)</td>
                                                                                <td>@AppState.FormatCurrency(period.MonthlyAmortization)</td>
                                                                                <td>
                                                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                                                   Color="Color.Error"
                                                                                                   Size="Size.Small"
                                                                                                   OnClick="@(() => HandleDeleteBindingPeriodAsync(period))" />
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    }
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </section>

                                                    <section class="card-panel">
                                                        <details>
                                                            <summary class="btn btn-outline-primary btn-sm">@Localizer["table.balance"]</summary>
                                                            <div class="table-responsive mt-3">
                                                                <table class="table app-table">
                                                                    <thead>
                                                                        <tr>
                                                                            <th>@Localizer["credits.month"]</th>
                                                                            <th>@Localizer["table.balance"]</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @if (!GetBalanceEntries(loan.Id).Any())
                                                                        {
                                                                            <tr>
                                                                                <td colspan="2" class="empty-state">@Localizer["table.noCostRows"]</td>
                                                                            </tr>
                                                                        }
                                                                        else
                                                                        {
                                                                            @foreach (var balance in GetBalanceEntries(loan.Id))
                                                                            {
                                                                                <tr>
                                                                                    <td>@($"{balance.Year:0000}/{balance.Month:00}")</td>
                                                                                    <td>@AppState.FormatCurrency(balance.Balance)</td>
                                                                                </tr>
                                                                            }
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </details>
                                                    </section>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </MudTabPanel>

</MudTabs>

@code {
    private HomeResidenceFormModel homeResidenceForm = new();
    private HousingCostFormModel costForm = new();
    private HousingDefinitionFormModel definitionForm = new();
    private HousingLoanFormModel loanForm = new();
    private readonly Dictionary<Guid, LoanBindingPeriodFormModel> bindingPeriodForms = [];
    private readonly Dictionary<Guid, EditContext> bindingPeriodEditContexts = [];
    private EditContext homeResidenceEditContext = default!;
    private EditContext costEditContext = default!;
    private EditContext definitionEditContext = default!;
    private EditContext loanEditContext = default!;
    private readonly HashSet<Guid> expandedLoanIds = [];
    private string? statusMessage;
    private bool showAllHousingCosts;
    private bool showAllHousingBindingPeriods;

    private static IReadOnlyList<ResidenceTypeOption> ResidenceTypeOptions { get; } =
    [
        new(HomeResidenceType.RentalApartment, "housing.residenceType.rentalApartment"),
        new(HomeResidenceType.Condominium, "housing.residenceType.condominium"),
        new(HomeResidenceType.House, "housing.residenceType.house")
    ];

    private IEnumerable<HousingCostDefinition> HousingDefinitions =>
        AppState.Data.HousingDefinitions
            .OrderBy(record => record.Subcategory)
            .ThenBy(record => record.StartYear)
            .ThenBy(record => record.StartMonth);

    private IReadOnlyList<HousingLoan> HousingLoans =>
        AppState.Data.HousingLoans
            .OrderBy(loan => loan.Name)
            .ThenBy(loan => loan.Lender)
            .ThenBy(loan => loan.LoanStartDate)
            .ToList();
    private decimal TotalHousingLoanAmortization => HousingLoans.Sum(GetActiveAmortizationAmount);
    private decimal TotalHousingLoanRemainingDebt => HousingLoans.Sum(loan => AppState.GetLoanCurrentBalance(loan.Id));

    private bool IsLoanExpanded(Guid loanId) => expandedLoanIds.Contains(loanId);

    private void ToggleLoanDetails(Guid loanId)
    {
        if (!expandedLoanIds.Add(loanId))
        {
            expandedLoanIds.Remove(loanId);
        }
    }

    private bool ShowsOwnedResidenceFields =>
        homeResidenceForm.ResidenceType is HomeResidenceType.Condominium or HomeResidenceType.House;

    protected override void OnInitialized()
    {
        AppState.Changed += HandleChanged;
        Localizer.Changed += HandleChanged;
        ResetForms();
    }

    private async Task HandleAddCostAsync()
    {
        var date = DateOnly.FromDateTime(costForm.Date!.Value);
        await AppState.AddOneTimeExpenseAsync(
            costForm.Amount,
            date.Year,
            date.Month,
            ExpenseCategory.Housing,
            costForm.Subcategory,
            costForm.Description,
            transactionDate: date);

        costForm = new HousingCostFormModel();
        ResetForms();
        statusMessage = Localizer["housing.costAdded"];
    }

    private async Task HandleAddDefinitionAsync()
    {
        var startDate = DateOnly.FromDateTime(definitionForm.StartDate!.Value);
        var endDate = DateOnly.FromDateTime(definitionForm.EndDate!.Value);
        if (endDate < startDate)
        {
            statusMessage = Localizer["validation.endDateOnOrAfterStartDate"];
            return;
        }

        await AppState.AddHousingDefinitionAsync(
            definitionForm.Amount,
            definitionForm.IntervalMonths,
            startDate.Year,
            startDate.Month,
            endDate.Year,
            endDate.Month,
            definitionForm.Subcategory,
            definitionForm.Description);

        definitionForm = new HousingDefinitionFormModel();
        ResetForms();
        statusMessage = Localizer["housing.definitionAdded"];
    }

    private async Task HandleAddLoanAsync()
    {
        await AppState.AddHousingLoanAsync(
            loanForm.Name,
            loanForm.Lender,
            DateOnly.FromDateTime(loanForm.LoanStartDate!.Value),
            loanForm.InitialLoanAmount,
            loanForm.RemainingDebt);

        loanForm = new HousingLoanFormModel();
        ResetForms();
        statusMessage = Localizer["housing.loanAdded"];
    }

    private async Task HandleSaveHomeResidenceAsync()
    {
        await AppState.SaveHomeResidenceAsync(
            homeResidenceForm.ResidenceType,
            homeResidenceForm.PurchaseYear,
            homeResidenceForm.PurchasePrice,
            homeResidenceForm.CurrentMarketValue);

        homeResidenceForm = CreateHomeResidenceForm();
        homeResidenceEditContext = new EditContext(homeResidenceForm);
        statusMessage = Localizer["housing.homeResidenceSaved"];
    }

    private async Task HandleAddBindingPeriodAsync(Guid loanId)
    {
        var form = GetBindingPeriodForm(loanId);
        var startDate = DateOnly.FromDateTime(form.StartDate!.Value);
        var endDate = DateOnly.FromDateTime(form.EndDate!.Value);

        if (endDate < startDate)
        {
            statusMessage = Localizer["validation.endDateOnOrAfterStartDate"];
            return;
        }

        try
        {
            await AppState.AddLoanInterestBindingPeriodAsync(loanId, startDate, endDate, form.InterestRate, form.MonthlyAmortization);
            bindingPeriodForms[loanId] = CreateBindingPeriodForm();
            bindingPeriodEditContexts[loanId] = new EditContext(bindingPeriodForms[loanId]);
            statusMessage = Localizer["housing.bindingPeriodAdded"];
        }
        catch (InvalidOperationException)
        {
            statusMessage = Localizer["validation.loanBindingPeriodOverlap"];
        }
    }

    private async Task HandleDeleteExpenseAsync(ExpenseEntry expense)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, string.Format(Localizer["housing.deleteCostMessage"], AppState.GetExpenseDescriptionDisplay(expense)) },
            { dialog => dialog.ConfirmText, Localizer["action.delete"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveExpenseAsync(expense.Id);
        statusMessage = Localizer["housing.costDeleted"];
    }

    private async Task HandleDeleteDefinitionAsync(HousingCostDefinition definition)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, string.Format(Localizer["housing.deleteDefinitionMessage"], definition.Subcategory) },
            { dialog => dialog.ConfirmText, Localizer["action.delete"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveHousingDefinitionAsync(definition.Id);
        statusMessage = Localizer["housing.definitionDeleted"];
    }

    private async Task HandleArchiveDefinitionAsync(HousingCostDefinition definition)
    {
        await AppState.ArchiveHousingDefinitionAsync(definition.Id);
        statusMessage = Localizer["housing.definitionArchived"];
    }

    private async Task HandleArchiveExpiredDefinitionsAsync()
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.archiveTitle"] },
            { dialog => dialog.Message, Localizer["housing.archiveExpiredDefinitionsMessage"] },
            { dialog => dialog.ConfirmText, Localizer["action.archiveAll"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] },
            { dialog => dialog.ConfirmColor, Color.Warning }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.archiveTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        var expiredDefinitions = AppState.Data.HousingDefinitions.Where(IsExpiredDefinition).ToList();
        var archivedCount = 0;

        foreach (var definition in expiredDefinitions)
        {
            if (await AppState.ArchiveHousingDefinitionAsync(definition.Id))
            {
                archivedCount++;
            }
        }

        statusMessage = archivedCount > 0
            ? string.Format(Localizer["definitions.archivedCount"], archivedCount)
            : Localizer["definitions.noneArchived"];
    }

    private void HandleRenewDefinition(HousingCostDefinition definition)
    {
        var nextStartDate = new DateTime(definition.EndYear, definition.EndMonth, 1).AddMonths(1);
        definitionForm = new HousingDefinitionFormModel
        {
            Description = definition.Description,
            Subcategory = definition.Subcategory,
            Amount = definition.Amount,
            IntervalMonths = definition.IntervalMonths,
            StartDate = nextStartDate,
            EndDate = null
        };

        definitionEditContext = new EditContext(definitionForm);
        statusMessage = Localizer["definitions.renewPrepared"];
    }

    private async Task HandleDeleteLoanAsync(HousingLoan loan)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, string.Format(Localizer["housing.deleteLoanMessage"], loan.Lender) },
            { dialog => dialog.ConfirmText, Localizer["action.delete"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveHousingLoanAsync(loan.Id);
        bindingPeriodForms.Remove(loan.Id);
        bindingPeriodEditContexts.Remove(loan.Id);
        statusMessage = Localizer["housing.loanDeleted"];
    }

    private async Task HandleBackfillLoanAmortizationAsync(Guid loanId)
    {
        var parameters = new DialogParameters<BackfillLoanAmortizationDialog>
        {
            { dialog => dialog.InitialAmortizationAmount, GetSuggestedBackfillAmortizationAmount(loanId) },
            { dialog => dialog.InitialInterestAmount, GetSuggestedBackfillInterestAmount(loanId) }
        };

        var dialog = await DialogService.ShowAsync<BackfillLoanAmortizationDialog>(Localizer["loans.backfillAmortization"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        if (result.Data is not BackfillLoanAmortizationDialog.BackfillLoanAmortizationDialogModel model ||
            !model.StartDate.HasValue ||
            !model.EndDate.HasValue)
        {
            return;
        }

        var createdCount = await AppState.BackfillLoanExpensesAsync(
            loanId,
            DateOnly.FromDateTime(model.StartDate.Value),
            DateOnly.FromDateTime(model.EndDate.Value),
            model.MonthlyAmortizationAmount,
            model.MonthlyInterestAmount);

        statusMessage = createdCount > 0
            ? string.Format(Localizer["loans.backfillCompleted"], createdCount)
            : Localizer["loans.backfillNothingCreated"];
    }

    private async Task HandleDeleteBindingPeriodAsync(LoanInterestBindingPeriod period)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, string.Format(Localizer["housing.deleteBindingPeriodMessage"], FormatDate(period.StartMonth), FormatDate(period.EndMonth)) },
            { dialog => dialog.ConfirmText, Localizer["action.delete"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveLoanInterestBindingPeriodAsync(period.Id);
        statusMessage = Localizer["housing.bindingPeriodDeleted"];
    }

    private Task HandleShowAllHousingCostsChanged(bool value)
    {
        showAllHousingCosts = value;
        return Task.CompletedTask;
    }

    private void ResetForms()
    {
        var today = DateTime.Today;

        homeResidenceForm = CreateHomeResidenceForm();
        costForm.Date ??= new DateTime(today.Year, today.Month, 1);
        definitionForm.StartDate ??= new DateTime(today.Year, today.Month, 1);
        definitionForm.EndDate ??= new DateTime(today.Year, today.Month, 1);
        definitionForm.IntervalMonths = 1;
        loanForm.LoanStartDate ??= today;

        homeResidenceEditContext = new EditContext(homeResidenceForm);
        costEditContext = new EditContext(costForm);
        definitionEditContext = new EditContext(definitionForm);
        loanEditContext = new EditContext(loanForm);
    }

    private bool HasExpiredDefinitions() => AppState.Data.HousingDefinitions.Any(IsExpiredDefinition);

    private static bool IsExpiredDefinition(HousingCostDefinition definition) =>
        new DateOnly(definition.EndYear, definition.EndMonth, 1) < new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1);

    private HomeResidenceFormModel CreateHomeResidenceForm()
    {
        var residence = AppState.Data.HomeResidence;
        return new HomeResidenceFormModel
        {
            ResidenceType = residence?.ResidenceType ?? HomeResidenceType.RentalApartment,
            PurchaseYear = residence?.PurchaseYear,
            PurchasePrice = residence?.PurchasePrice,
            CurrentMarketValue = residence?.CurrentMarketValue
        };
    }

    private LoanBindingPeriodFormModel GetBindingPeriodForm(Guid loanId)
    {
        EnsureLoanForms(loanId);
        return bindingPeriodForms[loanId];
    }

    private EditContext GetBindingPeriodEditContext(Guid loanId)
    {
        EnsureLoanForms(loanId);
        return bindingPeriodEditContexts[loanId];
    }

    private void EnsureLoanForms(Guid loanId)
    {
        if (!bindingPeriodForms.ContainsKey(loanId))
        {
            bindingPeriodForms[loanId] = CreateBindingPeriodForm();
            bindingPeriodEditContexts[loanId] = new EditContext(bindingPeriodForms[loanId]);
        }

    }

    private static LoanBindingPeriodFormModel CreateBindingPeriodForm()
    {
        var today = DateTime.Today;
        return new LoanBindingPeriodFormModel
        {
            StartDate = new DateTime(today.Year, today.Month, 1),
            EndDate = new DateTime(today.Year, today.Month, 1)
        };
    }

    private IReadOnlyList<LoanInterestBindingPeriod> GetLoanInterestBindingPeriods(Guid loanId) =>
        AppState.Data.LoanInterestBindingPeriods
            .Where(period => period.LoanId == loanId)
            .OrderBy(period => period.StartMonth)
            .ThenBy(period => period.EndMonth)
            .ToList();

    private IReadOnlyList<LoanInterestBindingPeriod> GetVisibleLoanInterestBindingPeriods(Guid loanId)
    {
        var periods = GetLoanInterestBindingPeriods(loanId);
        if (showAllHousingBindingPeriods)
        {
            return periods;
        }

        var activePeriod = GetActiveLoanInterestBindingPeriod(loanId);
        return activePeriod is null ? [] : [activePeriod];
    }

    private LoanInterestBindingPeriod? GetActiveLoanInterestBindingPeriod(Guid loanId)
    {
        var currentMonth = new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1);
        return GetLoanInterestBindingPeriods(loanId)
            .Where(period => CoversMonth(period.StartMonth, period.EndMonth, currentMonth))
            .OrderByDescending(period => period.StartMonth)
            .ThenByDescending(period => period.EndMonth)
            .FirstOrDefault();
    }

    private bool HasActiveBindingPeriod(Guid loanId) => GetActiveLoanInterestBindingPeriod(loanId) is not null;

    private string GetActiveBindingRateDisplay(Guid loanId)
    {
        var activePeriod = GetActiveLoanInterestBindingPeriod(loanId);
        return activePeriod is null ? "-" : FormatInterestRate(activePeriod.InterestRate);
    }

    private string GetActiveAmortizationDisplay(Guid loanId)
    {
        var activePeriod = GetActiveLoanInterestBindingPeriod(loanId);
        return activePeriod is null ? "-" : AppState.FormatCurrency(activePeriod.MonthlyAmortization);
    }

    private decimal GetActiveAmortizationAmount(HousingLoan loan)
    {
        var activePeriod = GetActiveLoanInterestBindingPeriod(loan.Id);
        return activePeriod?.MonthlyAmortization ?? loan.CurrentAmortization;
    }

    private decimal GetSuggestedBackfillAmortizationAmount(Guid loanId)
    {
        var activePeriod = GetActiveLoanInterestBindingPeriod(loanId);
        return activePeriod?.MonthlyAmortization ?? HousingLoans.FirstOrDefault(loan => loan.Id == loanId)?.CurrentAmortization ?? 0m;
    }

    private decimal GetSuggestedBackfillInterestAmount(Guid loanId)
    {
        _ = loanId;
        return 0m;
    }

    private string GetActiveBindingPeriodDisplay(Guid loanId)
    {
        var activePeriod = GetActiveLoanInterestBindingPeriod(loanId);
        return activePeriod is null
            ? "-"
            : $"{FormatYearMonth(activePeriod.StartMonth)}\u2014{FormatYearMonth(activePeriod.EndMonth)}";
    }

    private static bool CoversMonth(DateOnly startDate, DateOnly endDate, DateOnly month) =>
        NormalizeMonth(startDate) <= month && month <= NormalizeMonth(endDate);

    private static DateOnly NormalizeMonth(DateOnly date) => new(date.Year, date.Month, 1);

    private IReadOnlyList<MonthlyBalance> GetBalanceEntries(Guid entityId) =>
        AppState.GetMonthlyBalances(entityId);

    private IReadOnlyList<string> GetSubcategorySuggestions() =>
        AppState.GetExpenseSubcategorySuggestions(ExpenseCategory.Housing);

    private string GetIntervalLabel(int intervalMonths)
    {
        return intervalMonths switch
        {
            1 => Localizer["interval.monthly"],
            3 => Localizer["interval.quarterly"],
            6 => Localizer["interval.semiAnnual"],
            12 => Localizer["interval.yearly"],
            _ => string.Format(Localizer["housing.intervalFallback"], intervalMonths)
        };
    }

    private string GetMonthYearLabel(int year, int month) => $"{Localizer[$"month.{month}"]} {year}";

    private static string FormatDate(DateOnly date) => date.ToString("yyyy-MM-dd");

    private static string FormatYearMonth(DateOnly date) => date.ToString("yyyy/MM");

    private static string FormatInterestRate(decimal rate) => $"{rate:0.##}%";

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AppState.Changed -= HandleChanged;
        Localizer.Changed -= HandleChanged;
    }

