@page "/savings"
@implements IDisposable
@inject ApplicationState AppState
@inject IDialogService DialogService
@inject LocalizationService Localizer

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="status-banner">@statusMessage</div>
}

<MudTabs Class="section-tabs" Rounded="true" SliderColor="Color.Primary" Elevation="0">
    <MudTabPanel Text="@Localizer["savings.bankTab"]" Icon="@Icons.Material.Filled.AccountBalance">
        @RenderSavingsAccountTab(SavingsAccountType.Bank)
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["savings.fundsTab"]" Icon="@Icons.Material.Filled.ShowChart">
        @RenderSavingsAccountTab(SavingsAccountType.Fund)
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["savings.stocksTab"]" Icon="@Icons.Material.Filled.CandlestickChart">
        @RenderSavingsAccountTab(SavingsAccountType.Stock)
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["savings.transactionsTab"]" Icon="@Icons.Material.Filled.ReceiptLong">
        <section class="card-panel">
            <div class="section-title-row">
                <h2>@Localizer["savings.transactionsTab"]</h2>
            </div>

            <div class="form-grid mb-3">
                <div>
                    <label class="form-label">@Localizer["filter.name"]</label>
                    <InputText class="form-control" @bind-Value="returnsNameFilter" />
                </div>
                <div>
                    <label class="form-label">@Localizer["field.type"]</label>
                    <InputSelect class="form-select" @bind-Value="transactionTypeFilter">
                        <option value="">@Localizer["filter.allCategories"]</option>
                        <option value="@SavingsTransactionType.Deposit">@Localizer["savings.deposit"]</option>
                        <option value="@SavingsTransactionType.Withdrawal">@Localizer["savings.withdrawal"]</option>
                    </InputSelect>
                </div>
                <div>
                    <label class="form-label">@Localizer["field.category"]</label>
                    <InputSelect class="form-select" @bind-Value="returnsTypeFilter">
                        <option value="">@Localizer["filter.allCategories"]</option>
                        <option value="Bank">@Localizer["savings.bankTab"]</option>
                        <option value="Fund">@Localizer["savings.fundsTab"]</option>
                        <option value="Stock">@Localizer["savings.stocksTab"]</option>
                    </InputSelect>
                </div>
                <div>
                    <label class="form-label">@Localizer["filter.startDate"]</label>
                    <InputDate class="form-control" @bind-Value="returnsStartDate" />
                </div>
                <div>
                    <label class="form-label">@Localizer["filter.endDate"]</label>
                    <InputDate class="form-control" @bind-Value="returnsEndDate" />
                </div>
            </div>

            <div class="table-responsive">
                <table class="table app-table">
                    <thead>
                        <tr>
                            <th>@Localizer["field.name"]</th>
                            <th>@Localizer["field.type"]</th>
                            <th>@Localizer["field.category"]</th>
                            <th>@Localizer["table.period"]</th>
                            <th>@Localizer["field.amount"]</th>
                            <th>@Localizer["field.actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!FilteredTransactions.Any())
                        {
                            <tr>
                                <td colspan="6" class="empty-state">@Localizer["table.noCostRows"]</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var entry in FilteredTransactions)
                            {
                                <tr>
                                    <td>@entry.Name</td>
                                    <td>@Localizer[entry.TransactionType == SavingsTransactionType.Deposit ? "savings.deposit" : "savings.withdrawal"]</td>
                                    <td>@entry.CategoryDisplay</td>
                                    <td>@($"{entry.Year:0000}/{entry.Month:00}")</td>
                                    <td>@AppState.FormatCurrency(entry.Amount)</td>
                                    <td>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="@(() => HandleDeleteTransactionAsync(entry))" />
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </MudTabPanel>
</MudTabs>

@code {
    private readonly HashSet<Guid> expandedAccountIds = [];
    private string? statusMessage;
    private bool showAllPeriods;
    private string returnsNameFilter = string.Empty;
    private string transactionTypeFilter = string.Empty;
    private string returnsTypeFilter = string.Empty;
    private DateTime? returnsStartDate;
    private DateTime? returnsEndDate;

    private IEnumerable<ExpenseEntry> SavingsDepositEntries =>
        AppState.Data.ExpenseRecords
            .Where(entry => entry.SavingsAccountId.HasValue)
            .OrderByDescending(entry => entry.Year)
            .ThenByDescending(entry => entry.Month)
            .ThenBy(entry => entry.Subcategory)
            .ThenBy(entry => entry.Metadata);

    private IEnumerable<IncomeEntry> SavingsWithdrawalEntries =>
        AppState.Data.IncomeRecords
            .Where(entry => entry.SavingsAccountId.HasValue)
            .OrderByDescending(entry => entry.Year)
            .ThenByDescending(entry => entry.Month)
            .ThenBy(entry => entry.Type)
            .ThenBy(entry => entry.Metadata);

    private IReadOnlyList<SavingsTransactionListItem> FilteredTransactions =>
        SavingsDepositEntries
            .Select(entry => new SavingsTransactionListItem(
                entry.Id,
                SavingsTransactionType.Deposit,
                GetExpenseTransactionName(entry),
                GetSavingsAccountTypeValue(entry.SavingsAccountId),
                GetSavingsAccountTypeDisplay(entry.SavingsAccountId),
                entry.Year,
                entry.Month,
                entry.Amount))
            .Concat(SavingsWithdrawalEntries.Select(entry => new SavingsTransactionListItem(
                entry.Id,
                SavingsTransactionType.Withdrawal,
                GetIncomeDisplay(entry),
                entry.Type,
                GetSavingsCategoryDisplay(entry.Type),
                entry.Year,
                entry.Month,
                entry.Amount)))
            .Where(entry =>
                string.IsNullOrWhiteSpace(returnsNameFilter) ||
                entry.Name.Contains(returnsNameFilter.Trim(), StringComparison.OrdinalIgnoreCase))
            .Where(entry =>
                string.IsNullOrWhiteSpace(transactionTypeFilter) ||
                string.Equals(entry.TransactionType, transactionTypeFilter.Trim(), StringComparison.OrdinalIgnoreCase))
            .Where(entry =>
                string.IsNullOrWhiteSpace(returnsTypeFilter) ||
                string.Equals(entry.CategoryValue, returnsTypeFilter.Trim(), StringComparison.OrdinalIgnoreCase))
            .Where(entry =>
                !returnsStartDate.HasValue ||
                new DateOnly(entry.Year, entry.Month, 1) >= new DateOnly(returnsStartDate.Value.Year, returnsStartDate.Value.Month, 1))
            .Where(entry =>
                !returnsEndDate.HasValue ||
                new DateOnly(entry.Year, entry.Month, 1) <= new DateOnly(returnsEndDate.Value.Year, returnsEndDate.Value.Month, 1))
            .OrderByDescending(entry => entry.Year)
            .ThenByDescending(entry => entry.Month)
            .ThenBy(entry => entry.TransactionType)
            .ThenBy(entry => entry.Name)
            .ToList();

    protected override void OnInitialized()
    {
        AppState.Changed += HandleChanged;
        Localizer.Changed += HandleChanged;
    }

    private RenderFragment RenderSavingsAccountTab(SavingsAccountType accountType) => @<div>
        <div class="d-flex justify-content-end mb-3">
            <button class="btn btn-outline-primary" @onclick="() => HandleCreateAccountAsync(accountType)">@Localizer[GetCreateAccountTitleKey(accountType)]</button>
        </div>

        @if (!GetAccounts(accountType).Any())
        {
            <section class="card-panel">
                <p class="empty-state mb-0">@Localizer["savings.noAccounts"]</p>
            </section>
        }
        else
        {
            <section class="card-panel">
                <div class="table-responsive">
                    <table class="table app-table compact-overview-table">
                        <thead>
                            <tr>
                                <th class="expander-column"></th>
                                <th>@Localizer["field.name"]</th>
                                <th>@GetProviderColumnLabel(accountType)</th>
                                <th>@Localizer["field.status"]</th>
                                <th>@Localizer["savings.returnColumn"]</th>
                                <th>@Localizer["table.balance"]</th>
                                <th>@Localizer["savings.openingBalance"]</th>
                                <th>@Localizer["field.actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var account in GetAccounts(accountType))
                            {
                                <tr>
                                    <td class="expander-column">
                                        <MudIconButton Icon="@(IsAccountExpanded(account.Id) ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => ToggleAccountDetails(account.Id))" />
                                    </td>
                                    <td>@account.AccountName</td>
                                    <td>@GetProviderDisplay(account, accountType)</td>
                                    <td>@(HasActivePeriod(account.Id) ? "✔️" : "✖️")</td>
                                    <td>@GetActiveReturnDisplay(account)</td>
                                    <td>@AppState.FormatCurrency(AppState.GetSavingsAccountCurrentBalance(account.Id))</td>
                                    <td>@AppState.FormatCurrency(account.OpeningBalance)</td>
                                    <td>
                                        <div class="button-row">
                                            <button class="btn btn-outline-primary btn-sm" @onclick="() => HandleDepositAsync(account)">@Localizer["savings.deposit"]</button>
                                            <button class="btn btn-outline-primary btn-sm" @onclick="() => HandleWithdrawalAsync(account)">@Localizer["savings.withdrawal"]</button>
                                            <button class="btn btn-outline-primary btn-sm" @onclick="() => HandleAddPeriodAsync(account)">@Localizer["savings.addPeriod"]</button>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => HandleDeleteAccountAsync(account))" />
                                        </div>
                                    </td>
                                </tr>
                                @if (IsAccountExpanded(account.Id))
                                {
                                    <tr class="row-detail">
                                        <td colspan="8">
                                            <div class="inline-detail-shell">
                                                <section class="card-panel mt-4">
                                                    <div class="section-title-row">
                                                        <h3>@Localizer["savings.periods"]</h3>
                                                        <label class="form-check-label d-flex align-items-center gap-2">
                                                            <InputCheckbox class="form-check-input mt-0" @bind-Value="showAllPeriods" />
                                                            <span>@Localizer["filter.showAll"]</span>
                                                        </label>
                                                    </div>
                                                    <div class="table-responsive">
                                                        <table class="table app-table">
                                                            <thead>
                                                                <tr>
                                                                    <th>@Localizer["field.start"]</th>
                                                                    <th>@Localizer["field.end"]</th>
                                                                    <th>@Localizer[accountType == SavingsAccountType.Bank ? "savings.interestRate" : "savings.estimatedReturn"]</th>
                                                                    @if (accountType == SavingsAccountType.Bank)
                                                                    {
                                                                        <th>@Localizer["savings.taxPercent"]</th>
                                                                    }
                                                                    <th>@Localizer["field.actions"]</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @if (!GetVisiblePeriods(account.Id).Any())
                                                                {
                                                                    <tr>
                                                                        <td colspan="@(accountType == SavingsAccountType.Bank ? 5 : 4)" class="empty-state">@Localizer["savings.noPeriods"]</td>
                                                                    </tr>
                                                                }
                                                                else
                                                                {
                                                                    @foreach (var period in GetVisiblePeriods(account.Id))
                                                                    {
                                                                        <tr>
                                                                            <td>@period.StartDate.ToString("yyyy-MM-dd")</td>
                                                                            <td>@period.EndDate.ToString("yyyy-MM-dd")</td>
                                                                            <td>@($"{period.RatePercent:0.##}%")</td>
                                                                            @if (accountType == SavingsAccountType.Bank)
                                                                            {
                                                                                <td>@($"{period.TaxPercent:0.##}%")</td>
                                                                            }
                                                                            <td>
                                                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                                               Color="Color.Error"
                                                                                               Size="Size.Small"
                                                                                               OnClick="@(() => HandleDeletePeriodAsync(period))" />
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </section>

                                                <section class="card-panel mt-4">
                                                    <details>
                                                        <summary class="btn btn-outline-primary btn-sm">@Localizer["table.balance"]</summary>
                                                        <div class="table-responsive mt-3">
                                                            <table class="table app-table">
                                                                <thead>
                                                                    <tr>
                                                                        <th>@Localizer["credits.month"]</th>
                                                                        <th>@Localizer["table.balance"]</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    @if (!GetBalanceEntries(account.Id).Any())
                                                                    {
                                                                        <tr>
                                                                            <td colspan="2" class="empty-state">@Localizer["table.noCostRows"]</td>
                                                                        </tr>
                                                                    }
                                                                    else
                                                                    {
                                                                        @foreach (var balance in GetBalanceEntries(account.Id))
                                                                        {
                                                                            <tr>
                                                                                <td>@($"{balance.Year:0000}/{balance.Month:00}")</td>
                                                                                <td>@AppState.FormatCurrency(balance.Balance)</td>
                                                                            </tr>
                                                                        }
                                                                    }
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </details>
                                                </section>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }

                            <tr class="table-summary-row">
                                <td colspan="5" class="table-summary-label">@Localizer["table.sum"]</td>
                                <td class="table-summary-value">@AppState.FormatCurrency(GetTotalSavingsBalance(accountType))</td>
                                <td></td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </div>;

    private IReadOnlyList<SavingsAccount> GetAccounts(SavingsAccountType accountType) =>
        AppState.Data.SavingsAccounts
            .Where(account => account.AccountType == accountType)
            .OrderBy(account => account.AccountName)
            .ThenBy(account => account.ProviderName)
            .ToList();

    private decimal GetTotalSavingsBalance(SavingsAccountType accountType) =>
        GetAccounts(accountType).Sum(account => AppState.GetSavingsAccountCurrentBalance(account.Id));

    private IReadOnlyList<SavingsReturnPeriod> GetPeriods(Guid accountId) =>
        AppState.Data.SavingsReturnPeriods
            .Where(period => period.SavingsAccountId == accountId)
            .OrderBy(period => period.StartDate)
            .ThenBy(period => period.EndDate)
            .ToList();

    private IReadOnlyList<SavingsReturnPeriod> GetVisiblePeriods(Guid accountId)
    {
        var periods = GetPeriods(accountId);
        if (showAllPeriods)
        {
            return periods;
        }

        var activePeriod = GetActivePeriod(accountId);
        return activePeriod is null ? [] : [activePeriod];
    }

    private SavingsReturnPeriod? GetActivePeriod(Guid accountId)
    {
        var currentMonth = new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1);
        return GetPeriods(accountId)
            .Where(period => CoversMonth(period.StartDate, period.EndDate, currentMonth))
            .OrderByDescending(period => period.StartDate)
            .ThenByDescending(period => period.EndDate)
            .FirstOrDefault();
    }

    private bool HasActivePeriod(Guid accountId) => GetActivePeriod(accountId) is not null;

    private string GetActiveReturnDisplay(SavingsAccount account)
    {
        var activePeriod = GetActivePeriod(account.Id);
        return activePeriod is null ? "-" : $"{activePeriod.RatePercent:0.##}%";
    }

    private IReadOnlyList<MonthlyBalance> GetBalanceEntries(Guid entityId) =>
        AppState.GetMonthlyBalances(entityId);

    private string GetExpenseTransactionName(ExpenseEntry entry) =>
        AppState.GetExpenseDescriptionDisplay(entry);

    private string GetSavingsAccountTypeDisplay(Guid? savingsAccountId)
    {
        if (!savingsAccountId.HasValue)
        {
            return string.Empty;
        }

        var account = AppState.Data.SavingsAccounts.FirstOrDefault(item => item.Id == savingsAccountId.Value);
        return account is null ? string.Empty : GetSavingsCategoryDisplay(account.AccountType.ToString());
    }

    private string GetSavingsAccountTypeValue(Guid? savingsAccountId)
    {
        if (!savingsAccountId.HasValue)
        {
            return string.Empty;
        }

        var account = AppState.Data.SavingsAccounts.FirstOrDefault(item => item.Id == savingsAccountId.Value);
        return account?.AccountType.ToString() ?? string.Empty;
    }

    private string GetSavingsCategoryDisplay(string type) =>
        type switch
        {
            "Bank" => Localizer["savings.bankTab"],
            "Fund" => Localizer["savings.fundsTab"],
            "Stock" => Localizer["savings.stocksTab"],
            _ => type
        };

    private static bool CoversMonth(DateOnly startDate, DateOnly endDate, DateOnly month) =>
        NormalizeMonth(startDate) <= month && month <= NormalizeMonth(endDate);

    private static DateOnly NormalizeMonth(DateOnly date) => new(date.Year, date.Month, 1);

    private bool IsAccountExpanded(Guid accountId) => expandedAccountIds.Contains(accountId);

    private void ToggleAccountDetails(Guid accountId)
    {
        if (!expandedAccountIds.Add(accountId))
        {
            expandedAccountIds.Remove(accountId);
        }
    }

    private string GetProviderColumnLabel(SavingsAccountType accountType) => accountType switch
    {
        SavingsAccountType.Bank => Localizer["savings.bankName"],
        SavingsAccountType.Fund => Localizer["savings.depotName"],
        _ => Localizer["savings.depotName"]
    };

    private string GetProviderDisplay(SavingsAccount account, SavingsAccountType accountType) => accountType switch
    {
        SavingsAccountType.Bank => account.ProviderName,
        SavingsAccountType.Fund => account.ProviderName,
        _ => account.ProviderName
    };

    private string GetIncomeDisplay(IncomeEntry entry) =>
        string.IsNullOrWhiteSpace(entry.Metadata)
            ? AppState.GetIncomeTypeDisplay(entry.Type)
            : $"{entry.Metadata} - {AppState.GetIncomeTypeDisplay(entry.Type)}";

    private string GetCreateAccountTitleKey(SavingsAccountType accountType) => accountType switch
    {
        SavingsAccountType.Bank => "savings.createBankAccount",
        SavingsAccountType.Fund => "savings.createFundAccount",
        _ => "savings.createStockAccount"
    };

    private async Task HandleCreateAccountAsync(SavingsAccountType accountType)
    {
        var parameters = new DialogParameters<CreateSavingsAccountDialog>
        {
            { dialog => dialog.AccountType, accountType }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreateSavingsAccountDialog>(Localizer[GetCreateAccountTitleKey(accountType)], parameters, options);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        if (result.Data is not CreateSavingsAccountDialog.CreateSavingsAccountDialogModel model)
        {
            return;
        }

        await AppState.AddSavingsAccountAsync(
            accountType,
            model.ProviderName,
            model.AccountName,
            model.CurrentBalance,
            model.CurrentPeriod,
            model.BackfillDeposits,
            model.BackfillDeposits ? model.BackfillStartPeriod : null,
            model.BackfillDeposits ? model.BackfillStartBalance : null);
        statusMessage = Localizer["savings.accountCreated"];
    }

    private async Task HandleAddPeriodAsync(SavingsAccount account)
    {
        var parameters = new DialogParameters<AddSavingsReturnPeriodDialog>
        {
            { dialog => dialog.AccountType, account.AccountType }
        };

        var dialog = await DialogService.ShowAsync<AddSavingsReturnPeriodDialog>(Localizer["savings.addPeriod"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        if (result.Data is not AddSavingsReturnPeriodDialog.AddSavingsReturnPeriodDialogModel model || !model.StartDate.HasValue || !model.EndDate.HasValue)
        {
            return;
        }

        var startDate = DateOnly.FromDateTime(model.StartDate.Value);
        var endDate = DateOnly.FromDateTime(model.EndDate.Value);
        if (endDate < startDate)
        {
            statusMessage = Localizer["validation.endDateOnOrAfterStartDate"];
            return;
        }

        try
        {
            await AppState.AddSavingsReturnPeriodAsync(account.Id, startDate, endDate, model.RatePercent, model.TaxPercent);
            statusMessage = Localizer["savings.periodAdded"];
        }
        catch (InvalidOperationException)
        {
            statusMessage = Localizer["validation.savingsPeriodOverlap"];
        }
    }

    private async Task HandleDepositAsync(SavingsAccount account)
    {
        var parameters = new DialogParameters<RegisterSavingsDepositDialog>
        {
            { dialog => dialog.SavingsAccountId, account.Id }
        };

        var dialog = await DialogService.ShowAsync<RegisterSavingsDepositDialog>(Localizer["savings.deposit"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        if (result.Data is not SavingsAmountDialogModel model || !model.Date.HasValue)
        {
            return;
        }

        await AppState.AddSavingsDepositAsync(model.SavingsAccountId ?? account.Id, DateOnly.FromDateTime(model.Date.Value), model.Amount, model.IsAdjustment);
        statusMessage = Localizer[model.IsAdjustment ? "savings.balanceAdjusted" : "savings.depositRegistered"];
    }

    private async Task HandleWithdrawalAsync(SavingsAccount account)
    {
        var dialog = await DialogService.ShowAsync<RegisterSavingsWithdrawalDialog>(Localizer["savings.withdrawal"]);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        if (result.Data is not SavingsAmountDialogModel model || !model.Date.HasValue)
        {
            return;
        }

        try
        {
            await AppState.AddSavingsWithdrawalAsync(account.Id, DateOnly.FromDateTime(model.Date.Value), model.Amount, model.IsAdjustment);
            statusMessage = Localizer[model.IsAdjustment ? "savings.balanceAdjusted" : "savings.withdrawalRegistered"];
        }
        catch (InvalidOperationException)
        {
            statusMessage = Localizer["validation.savingsWithdrawalExceedsBalance"];
        }
    }

    private async Task HandleDeleteAccountAsync(SavingsAccount account)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, string.Format(Localizer["savings.deleteAccountMessage"], account.AccountName) },
            { dialog => dialog.ConfirmText, Localizer["action.delete"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveSavingsAccountAsync(account.Id);
        statusMessage = Localizer["savings.accountDeleted"];
    }

    private async Task HandleDeletePeriodAsync(SavingsReturnPeriod period)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, string.Format(Localizer["savings.deletePeriodMessage"], period.StartDate.ToString("yyyy-MM-dd"), period.EndDate.ToString("yyyy-MM-dd")) },
            { dialog => dialog.ConfirmText, Localizer["action.delete"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveSavingsReturnPeriodAsync(period.Id);
        statusMessage = Localizer["savings.periodDeleted"];
    }

    private async Task HandleDeleteSavingsExpenseAsync(ExpenseEntry expense)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, string.Format(Localizer["savings.deleteCostMessage"], AppState.GetExpenseSubcategoryDisplay(expense)) },
            { dialog => dialog.ConfirmText, Localizer["action.delete"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveExpenseAsync(expense.Id);
        statusMessage = Localizer["savings.costDeleted"];
    }

    private async Task HandleDeleteSavingsIncomeAsync(IncomeEntry income)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, string.Format(Localizer["savings.deleteReturnMessage"], GetIncomeDisplay(income)) },
            { dialog => dialog.ConfirmText, Localizer["action.delete"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveIncomeAsync(income.Id, removeSeries: false);
        statusMessage = Localizer["savings.returnDeleted"];
    }

    private Task HandleDeleteTransactionAsync(SavingsTransactionListItem entry) =>
        entry.TransactionType == SavingsTransactionType.Deposit
            ? HandleDeleteSavingsExpenseAsync(AppState.Data.ExpenseRecords.First(item => item.Id == entry.Id))
            : HandleDeleteSavingsIncomeAsync(AppState.Data.IncomeRecords.First(item => item.Id == entry.Id));

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AppState.Changed -= HandleChanged;
        Localizer.Changed -= HandleChanged;
    }

    private static class SavingsTransactionType
    {
        public const string Deposit = "Deposit";
        public const string Withdrawal = "Withdrawal";
    }

    private sealed record SavingsTransactionListItem(
        Guid Id,
        string TransactionType,
        string Name,
        string CategoryValue,
        string CategoryDisplay,
        int Year,
        int Month,
        decimal Amount);
}
