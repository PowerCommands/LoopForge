    private async Task HandleDeleteAllLocalStorageFilesAsync()
    {
        var existingFiles = LocalStorageFiles.Where(file => file.Exists).ToList();
        if (existingFiles.Count == 0)
        {
            return;
        }

        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["settings.deleteAllFilesTitle"] },
            { dialog => dialog.Message, Localizer["settings.deleteAllFilesMessage"] },
            { dialog => dialog.ConfirmText, Localizer["action.deleteAll"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] },
            { dialog => dialog.ConfirmColor, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["settings.deleteAllFilesTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        foreach (var file in existingFiles)
        {
            await LocalStorageService.RemoveAsync(file.Key);
        }

        await ReloadLocalStorageBackedStateAsync();
        statusMessage = Localizer["settings.allFilesDeleted"];
    }

