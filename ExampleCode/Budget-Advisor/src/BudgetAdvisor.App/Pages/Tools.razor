    private void HandleChanged() => _ = InvokeAsync(RefreshStateAsync);

    private async Task RefreshStateAsync()
    {
        SyncUiStateFromService();
        RebuildApplicationDataSections();
        await RefreshStorageInsightsAsync();
        StateHasChanged();
    }

    private async Task RefreshStorageInsightsAsync()
    {
        StorageUsage = await BrowserStorageUsageService.GetUsageAsync();
        await RefreshLocalStorageFilesAsync();
    }

    private async Task RefreshLocalStorageFilesAsync()
    {
        LocalStorageFiles = [];

        foreach (var descriptor in GetManagedLocalStorageFiles())
        {
            var json = await LocalStorageService.LoadJsonAsync(descriptor.Key);
            LocalStorageFiles.Add(new LocalStorageFileRow(
                descriptor.Key,
                descriptor.Description,
                CountLocalStorageRecords(descriptor.Key, json),
                !string.IsNullOrWhiteSpace(json)));
        }
    }

    private async Task ReloadLocalStorageBackedStateAsync()
    {
        await AppState.ReloadFromStorageAsync();
        await ApplicationLogService.ReloadAsync();
        await Localizer.ReloadAsync();
        await SyncService.ReloadAsync();
        LoadEditableSubcategoryDefinitions();
        RebuildApplicationDataSections();
        SyncUiStateFromService();
        await RefreshStorageInsightsAsync();
        StateHasChanged();
    }

    private void SyncUiStateFromService()
    {
        isDropboxConnected = SyncService.Metadata.IsConnected;
