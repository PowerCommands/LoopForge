    private IReadOnlyList<ManagedLocalStorageFile> GetManagedLocalStorageFiles() =>
    [
        new(ApplicationState.ApplicationDataKey, Localizer["settings.file.applicationData"]),
        new(BudgetAdvisor.Services.ApplicationLogService.ApplicationLogKey, Localizer["settings.file.applicationLog"]),
        new(ApplicationState.TransactionImportDataKey, Localizer["settings.file.transactionImport"])
    ];

    private int CountLocalStorageRecords(string key, string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return 0;
        }

        return key switch
        {
            var value when string.Equals(value, ApplicationState.ApplicationDataKey, StringComparison.Ordinal) => CountApplicationDataRecords(json),
            var value when string.Equals(value, BudgetAdvisor.Services.ApplicationLogService.ApplicationLogKey, StringComparison.Ordinal) => LocalStorageService.Deserialize<List<ApplicationLogEntry>>(json)?.Count ?? 0,
            var value when string.Equals(value, ApplicationState.TransactionImportDataKey, StringComparison.Ordinal) =>
                (LocalStorageService.Deserialize<TransactionImportData>(json)?.ImportedExpenseCategorySuggestions.Count ?? 0) +
                (LocalStorageService.Deserialize<TransactionImportData>(json)?.ImportBatches.Count ?? 0),
            _ => CountJsonItems(json)
        };
    }

    private int CountApplicationDataRecords(string json)
    {
        var data = LocalStorageService.Deserialize<ApplicationData>(json);
        if (data is null)
        {
            return 0;
        }

        return data.Members.Count +
               data.IncomeRecords.Count +
               data.SalaryIncomePeriods.Count +
               data.SubcategoryDefinitions.Count +
               data.ExpenseRecords.Count +
               data.Subscriptions.Count +
               data.HousingDefinitions.Count +
               data.HousingLoans.Count +
               (data.HomeResidence is null ? 0 : 1) +
               data.TransportDefinitions.Count +
               data.TransportVehicles.Count +
               data.TransportLoans.Count +
               data.LoanInterestBindingPeriods.Count +
               data.LoanAmortizationPlans.Count +
               data.MonthlyBalances.Count +
               data.ClosedMonths.Count +
               data.TransportLeasingContracts.Count +
               data.Credits.Count +
               data.Debts.Count +
               data.SavingsAccounts.Count +
               data.SavingsReturnPeriods.Count +
               data.SavingsBalanceAdjustments.Count +
               data.SavingsGeneratedReturns.Count +
               data.Savings.Count;
    }

    private static int CountJsonItems(string json)
    {
        using var document = JsonDocument.Parse(json);
        return document.RootElement.ValueKind switch
        {
            JsonValueKind.Array => document.RootElement.GetArrayLength(),
            JsonValueKind.Object => document.RootElement.EnumerateObject().Count(),
            JsonValueKind.String => string.IsNullOrWhiteSpace(document.RootElement.GetString()) ? 0 : 1,
            JsonValueKind.Null or JsonValueKind.Undefined => 0,
            _ => 1
        };
    }

