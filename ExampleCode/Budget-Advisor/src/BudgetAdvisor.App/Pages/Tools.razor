@page "/tools"
@page "/settings"
@implements IDisposable
@using System.Reflection
@using System.Text.Json
@inject ApplicationState AppState
@inject LocalizationService Localizer
@inject IApplicationLogService ApplicationLogService
@inject IBrowserStorageUsageService BrowserStorageUsageService
@inject ManualSyncService SyncService
@inject IDialogService DialogService
@inject LocalStorageService LocalStorageService
@using BudgetAdvisor.Domain.Theming

<MudStack Spacing="3">
    <div class="page-header">
        <div>
            <h1>@Localizer["settings.title"]</h1>
            <p>@Localizer["settings.subtitle"]</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Filled">@statusMessage</MudAlert>
    }

    <MudTabs Rounded="true" SliderColor="Color.Primary" Elevation="0">
        <MudTabPanel Text="@Localizer["settings.tab.data"]" Icon="@Icons.Material.Filled.Storage">
            <MudGrid Spacing="3" Class="mt-1">
                <MudItem xs="12">
                    <MudPaper Class="card-panel" Elevation="0">
                        <MudStack Spacing="3">
                            <div class="section-title-row">
                                <div>
                                    <MudText Typo="Typo.h5">@Localizer["sync.cloudStorage"]</MudText>
                                </div>
                            </div>

                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="8">
                                    <MudPaper Class="card-panel settings-card cloud-sync-provider-card" Elevation="0">
                                        <MudStack Spacing="2">
                                            <div class="cloud-sync-provider-header">
                                                <img src="images/dropbox.png" alt="Dropbox" class="cloud-sync-provider-logo" />
                                                <div>
                                                    <MudText Typo="Typo.h6">@Localizer["sync.provider.dropbox"]</MudText>
                                                    <MudText Typo="Typo.body2">
                                                        @Localizer["sync.dropboxDescription"]
                                                    </MudText>
                                                </div>
                                            </div>

                                            <MudDivider />

                                            <MudText Typo="Typo.body2"><strong>@Localizer["sync.connectionStatus"]:</strong> @GetConnectionStatusText()</MudText>
                                            <MudText Typo="Typo.body2"><strong>@Localizer["sync.provider"]:</strong> @SyncService.Metadata.ProviderName</MudText>
                                            <MudText Typo="Typo.body2"><strong>@Localizer["sync.connectedAccount"]:</strong> @GetConnectedAccountText()</MudText>
                                            <MudText Typo="Typo.body2"><strong>@Localizer["sync.lastUpload"]:</strong> @FormatSyncTimestamp(SyncService.Metadata.LastUploadUtc)</MudText>
                                            <MudText Typo="Typo.body2"><strong>@Localizer["sync.lastDownload"]:</strong> @FormatSyncTimestamp(SyncService.Metadata.LastDownloadUtc)</MudText>
                                            <MudText Typo="Typo.body2"><strong>@Localizer["sync.files"]:</strong> @string.Join(", ", SyncService.Files.Select(file => file.DisplayName))</MudText>

                                            @if (SyncService.IsBusy)
                                            {
                                                <div class="cloud-sync-progress">
                                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Rounded="true" />
                                                    <MudText Typo="Typo.body2">@GetSyncProgressText()</MudText>
                                                </div>
                                            }

                                            <div class="button-row">
                                                <MudTooltip Text="@Localizer["sync.connect"]">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Link"
                                                                   Color="Color.Primary"
                                                                   Disabled="@SyncService.IsBusy"
                                                                   OnClick="HandleConnectToDropboxAsync"
                                                                   aria-label="@Localizer["sync.connect"]" />
                                                </MudTooltip>
                                                <MudTooltip Text="@Localizer["sync.upload"]">
                                                    <MudIconButton Icon="@Icons.Material.Filled.CloudUpload"
                                                                   Color="Color.Primary"
                                                                   Disabled="@(!isDropboxConnected || SyncService.IsBusy)"
                                                                   OnClick="HandleUploadToDropboxAsync"
                                                                   aria-label="@Localizer["sync.upload"]" />
                                                </MudTooltip>
                                                <MudTooltip Text="@Localizer["sync.download"]">
                                                    <MudIconButton Icon="@Icons.Material.Filled.CloudDownload"
                                                                   Color="Color.Secondary"
                                                                   Disabled="@(!isDropboxConnected || SyncService.IsBusy)"
                                                                   OnClick="HandleDownloadFromDropboxAsync"
                                                                   aria-label="@Localizer["sync.download"]" />
                                                </MudTooltip>
                                            </div>

                                            @if (latestSyncResult is not null)
                                            {
                                                <MudAlert Severity="@GetSyncResultSeverity()" Variant="Variant.Outlined">
                                                    @($"{latestSyncResult.Operation}: {latestSyncResult.Message}")
                                                </MudAlert>
                                            }
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="card-panel settings-card" Elevation="0">
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.h6">@Localizer["settings.applicationData"]</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.applicationDataHelp"]</MudText>
                            </div>
                            <div class="button-row">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleExportDataAsync">@Localizer["action.exportBackup"]</MudButton>
                                <label class="mud-upload-label">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" HtmlTag="span">@Localizer["action.importBackup"]</MudButton>
                                    <InputFile OnChange="HandleImportDataAsync" accept=".zip,.json,application/zip,application/json" hidden />
                                </label>
                            </div>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="card-panel settings-card" Elevation="0">
                        <MudStack Spacing="2" AlignItems="AlignItems.Center">
                            <div class="text-center">
                                <MudText Typo="Typo.h6">LocalDB</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.localDbHelp"]</MudText>
                            </div>

                            <MudChart ChartType="ChartType.Donut"
                                      InputData="@StorageChartData"
                                      InputLabels="@StorageChartLabels"
                                      ChartOptions="@StorageChartOptions"
                                      Width="220px"
                                      Height="220px" />

                            <MudStack Spacing="1" Class="w-100">
                                <MudText Typo="Typo.body2">@Localizer["settings.storageUsed"]: @FormatStorageMb(StorageUsage.DisplayUsedBytes)</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.storageFree"]: @FormatStorageMb(StorageUsage.FreeBytes)</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.storageTotal"]: @FormatStorageMb(StorageUsage.TotalBytes)</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="card-panel settings-card" Elevation="0">
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.h6">@Localizer["settings.dataPruning"]</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.dataPruningHelp"]</MudText>
                            </div>

                            <div>
                                <label class="form-label">@Localizer["settings.dataPruningCutoff"]</label>
                                <InputDate class="form-control" @bind-Value="pruningCutoffDate" />
                            </div>

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Warning"
                                       Disabled="@(!pruningCutoffDate.HasValue)"
                                       OnClick="HandlePruneDataAsync">
                                @Localizer["action.pruneData"]
                            </MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="card-panel" Elevation="0">
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.h6">@Localizer["settings.files"]</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.filesHelp"]</MudText>
                            </div>

                            <div class="table-responsive">
                                <table class="table app-table">
                                    <thead>
                                        <tr>
                                            <th>@Localizer["field.name"]</th>
                                            <th>@Localizer["field.description"]</th>
                                            <th>@Localizer["field.records"]</th>
                                            <th>
                                                <div class="d-flex align-items-center justify-content-between gap-2">
                                                    <span>@Localizer["field.actions"]</span>
                                                    <button type="button"
                                                            class="btn btn-outline-danger btn-sm d-inline-flex align-items-center gap-2"
                                                            disabled="@(!LocalStorageFiles.Any(file => file.Exists))"
                                                            @onclick="HandleDeleteAllLocalStorageFilesAsync">
                                                        <MudIcon Icon="@Icons.Material.Filled.DeleteSweep" Size="Size.Small" />
                                                        <span>@Localizer["action.deleteAll"]</span>
                                                    </button>
                                                </div>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var file in LocalStorageFiles)
                                        {
                                            <tr>
                                                <td>@file.Key</td>
                                                <td>@file.Description</td>
                                                <td>@file.RecordCount</td>
                                                <td>
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                   Color="Color.Error"
                                                                   Size="Size.Small"
                                                                   Disabled="@(!file.Exists)"
                                                                   OnClick="@(() => HandleDeleteLocalStorageFileAsync(file))" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="card-panel" Elevation="0">
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.h6">Application data</MudText>
                            </div>

                            @foreach (var dataSection in ApplicationDataSections)
                            {
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <MudIconButton Icon="@(dataSection.IsExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                                       Size="Size.Small"
                                                       OnClick="@(() => ToggleApplicationDataSection(dataSection.Key))" />
                                        <MudText Typo="Typo.subtitle1">@($"{dataSection.Name} ({dataSection.RowCount})")</MudText>
                                    </div>

                                    @if (dataSection.IsExpanded)
                                    {
                                        <div class="table-responsive">
                                            <table class="table app-table">
                                                <thead>
                                                    <tr>
                                                        @foreach (var column in dataSection.Columns)
                                                        {
                                                            <th>@column</th>
                                                        }
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @if (dataSection.Rows.Count == 0)
                                                    {
                                                        <tr>
                                                            <td colspan="@(Math.Max(1, dataSection.Columns.Count))">No rows</td>
                                                        </tr>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var row in dataSection.Rows)
                                                        {
                                                            <tr>
                                                                @foreach (var cell in row.Cells)
                                                                {
                                                                    <td>@cell</td>
                                                                }
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="@Localizer["settings.tab.regional"]" Icon="@Icons.Material.Filled.Language">
            <MudGrid Spacing="3" Class="mt-1">
                <MudItem xs="12" md="4">
                    <MudPaper Class="card-panel settings-card" Elevation="0">
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.h6">@Localizer["settings.language"]</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.languageHelp"]</MudText>
                            </div>
                            <MudSelect T="string"
                                       Label="@Localizer["language.select"]"
                                       Value="@Localizer.CurrentLanguage"
                                       ValueChanged="HandleLanguageChangedAsync"
                                       Variant="Variant.Outlined">
                                @foreach (var language in Localizer.Languages)
                                {
                                    <MudSelectItem T="string" Value="@language">@Localizer[$"language.{language}"]</MudSelectItem>
                                }
                            </MudSelect>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="card-panel settings-card" Elevation="0">
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.h6">@Localizer["settings.currency"]</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.currencyHelp"]</MudText>
                            </div>
                            <MudSelect T="string"
                                       Label="@Localizer["settings.currency"]"
                                       Value="@AppState.Data.CurrencyCode"
                                       ValueChanged="HandleCurrencyChangedAsync"
                                       Variant="Variant.Outlined">
                                @foreach (var currencyCode in CurrencyCodes)
                                {
                                    <MudSelectItem T="string" Value="@currencyCode">@Localizer[$"currency.{currencyCode}"]</MudSelectItem>
                                }
                            </MudSelect>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="card-panel settings-card" Elevation="0">
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.h6">@Localizer["settings.regional"]</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.regionalHelp"]</MudText>
                            </div>
                            <MudSelect T="string"
                                       Label="@Localizer["settings.decimalSeparator"]"
                                       Value="@AppState.Data.DecimalSeparator"
                                       ValueChanged="HandleDecimalSeparatorChangedAsync"
                                       Variant="Variant.Outlined">
                                <MudSelectItem T="string" Value="@DotSeparator">.</MudSelectItem>
                                <MudSelectItem T="string" Value="@CommaSeparator">,</MudSelectItem>
                            </MudSelect>
                            <MudSelect T="string"
                                       Label="@Localizer["settings.thousandsSeparator"]"
                                       Value="@AppState.Data.ThousandsSeparator"
                                       ValueChanged="HandleThousandsSeparatorChangedAsync"
                                       Variant="Variant.Outlined">
                                <MudSelectItem T="string" Value="@SpaceThousandsSeparator">@Localizer["settings.thousandsSeparator.space"]</MudSelectItem>
                                <MudSelectItem T="string" Value="@CommaSeparator">,</MudSelectItem>
                                <MudSelectItem T="string" Value="@DotSeparator">.</MudSelectItem>
                                <MudSelectItem T="string" Value="@NoThousandsSeparator">@Localizer["settings.thousandsSeparator.none"]</MudSelectItem>
                            </MudSelect>
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                @Localizer["settings.preview"]: @AppState.FormatCurrency(1234567.89m)
                            </MudAlert>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="card-panel settings-card" Elevation="0">
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.h6">@Localizer["settings.localizationExport"]</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.localizationImportHelp"]</MudText>
                            </div>
                            <div class="button-row">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleExportLocalizationAsync">@Localizer["action.downloadLocalization"]</MudButton>
                                <label class="mud-upload-label">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" HtmlTag="span">@Localizer["action.uploadLocalization"]</MudButton>
                                    <InputFile OnChange="HandleImportLocalizationAsync" accept=".json,application/json" hidden />
                                </label>
                            </div>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="card-panel" Elevation="0">
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.h6">@Localizer["settings.subcategories"]</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.subcategoriesHelp"]</MudText>
                            </div>

                            <div class="form-grid">
                                <div>
                                    <label class="form-label">@Localizer["settings.subcategoryMainCategory"]</label>
                                    <MudSelect T="SubcategoryMainCategory"
                                               Value="@selectedSubcategoryMainCategory"
                                               ValueChanged="HandleSubcategoryMainCategoryChangedAsync"
                                               Variant="Variant.Outlined">
                                        @foreach (var category in EditableSubcategoryMainCategories)
                                        {
                                            <MudSelectItem T="SubcategoryMainCategory" Value="@category">@GetSubcategoryMainCategoryDisplay(category)</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                            </div>

                            <div class="table-responsive">
                                <table class="table app-table">
                                    <thead>
                                        <tr>
                                            <th>@Localizer["language.sv"]</th>
                                            <th>@Localizer["language.en"]</th>
                                            <th>@Localizer["field.actions"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (editableSubcategoryDefinitions.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="3" class="empty-state">@Localizer["settings.noSubcategories"]</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var definition in editableSubcategoryDefinitions)
                                            {
                                                <tr>
                                                    <td>
                                                        <InputText class="form-control" @bind-Value="definition.SwedishName" />
                                                    </td>
                                                    <td>
                                                        <InputText class="form-control" @bind-Value="definition.EnglishName" />
                                                    </td>
                                                    <td>
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                       Color="Color.Error"
                                                                       Size="Size.Small"
                                                                       OnClick="@(() => RemoveSubcategoryDefinition(definition))" />
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="button-row">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="AddSubcategoryDefinition">@Localizer["settings.addSubcategory"]</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleSaveSubcategoryDefinitionsAsync">@Localizer["action.save"]</MudButton>
                            </div>
                        </MudStack>
                    </MudPaper>
                </MudItem>

            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="@Localizer["settings.tab.appearance"]" Icon="@Icons.Material.Filled.Palette">
            <MudGrid Spacing="3" Class="mt-1">
                <MudItem xs="12" md="4">
                    <MudPaper Class="card-panel settings-card" Elevation="0">
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.h6">@Localizer["settings.theme"]</MudText>
                                <MudText Typo="Typo.body2">@Localizer["settings.themeHelp"]</MudText>
                            </div>
                            <MudSelect T="string"
                                       Label="@Localizer["settings.theme"]"
                                       Value="@AppState.Data.ThemeMode"
                                       ValueChanged="HandleThemeModeChangedAsync"
                                       Variant="Variant.Outlined">
                                @foreach (var themeName in AppThemeNames.Names)
                                {
                                    <MudSelectItem T="string" Value="@themeName">@Localizer[$"settings.theme.{themeName}"]</MudSelectItem>
                                }
                            </MudSelect>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="@Localizer["settings.tab.log"]" Icon="@Icons.Material.Filled.History">
            <MudGrid Spacing="3" Class="mt-1">
                <MudItem xs="12">
                    <MudPaper Class="card-panel settings-card" Elevation="0">
                        <MudStack Spacing="2">
                            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                                <div>
                                    <MudText Typo="Typo.h6">@Localizer["settings.activityLog"]</MudText>
                                    <MudText Typo="Typo.body2">@Localizer["settings.activityLogHelp"]</MudText>
                                </div>
                                <div class="button-row">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleDownloadLogAsync">@Localizer["action.downloadLog"]</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="HandleClearLogAsync">@Localizer["action.clearLog"]</MudButton>
                                </div>
                            </div>

                            @if (ApplicationLogService.Entries.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                    @Localizer["settings.noActivityLogEntries"]
                                </MudAlert>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table app-table">
                                        <thead>
                                            <tr>
                                                <th>@Localizer["field.timestamp"]</th>
                                                <th>@Localizer["field.description"]</th>
                                                <th>@Localizer["field.activity"]</th>
                                                <th>@Localizer["field.status"]</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var entry in ApplicationLogService.Entries)
                                            {
                                                <tr>
                                                    <td>@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                                    <td>@entry.Description</td>
                                                    <td>@entry.Activity</td>
                                                    <td>@entry.Status</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
</MudStack>

@code {
    private const string DotSeparator = ".";
    private const string CommaSeparator = ",";
    private const string SpaceThousandsSeparator = " ";
    private const string NoThousandsSeparator = "";
    private static readonly string[] CurrencyCodes = ["SEK", "USD", "EUR", "GBP"];
    private static readonly IReadOnlyList<SubcategoryMainCategory> EditableSubcategoryMainCategories = Enum.GetValues<SubcategoryMainCategory>();
    private BrowserStorageUsageSnapshot StorageUsage { get; set; } = new();
    private DateTime? pruningCutoffDate;
    private string? statusMessage;
    private bool isDropboxConnected;
    private SubcategoryMainCategory selectedSubcategoryMainCategory = SubcategoryMainCategory.Income;
    private List<SubcategoryDefinition> editableSubcategoryDefinitions = [];
    private List<LocalStorageFileRow> LocalStorageFiles { get; set; } = [];
    private List<ApplicationDataSection> ApplicationDataSections { get; set; } = [];
    private Dictionary<string, bool> ExpandedApplicationDataSections { get; set; } = new(StringComparer.Ordinal);
    private SyncResult? latestSyncResult;

    protected override async Task OnInitializedAsync()
    {
        Localizer.Changed += HandleChanged;
        AppState.Changed += HandleChanged;
        ApplicationLogService.Changed += HandleChanged;
        SyncService.Changed += HandleChanged;
        LoadEditableSubcategoryDefinitions();
        RebuildApplicationDataSections();
        await SyncService.InitializeAsync();
        SyncUiStateFromService();
        await RefreshStorageInsightsAsync();
    }

    private double[] StorageChartData =>
    [
        Convert.ToDouble(StorageUsage.DisplayUsedBytes),
        Convert.ToDouble(StorageUsage.FreeBytes)
    ];

    private string[] StorageChartLabels =>
    [
        Localizer["settings.storageUsed"],
        Localizer["settings.storageFree"]
    ];

    private string[] StorageChartPalette =>
    [
        GetUsedStorageColor(StorageUsage.DisplayUsedBytes),
        "#2E7D32"
    ];

    private ChartOptions StorageChartOptions => new()
    {
        ChartPalette = StorageChartPalette,
        ShowLegend = true,
        ShowLabels = false
    };

    private async Task HandleExportDataAsync()
    {
        await AppState.ExportAsync();
        statusMessage = Localizer["settings.backupExported"];
    }

    private async Task HandleImportDataAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        var fileBytes = await ReadFileBytesAsync(file);
        await AppState.ImportAsync(fileBytes, file.Name);
        statusMessage = Localizer["settings.backupImported"];
    }

    private async Task HandleExportLocalizationAsync()
    {
        await Localizer.ExportLanguageAsync(Localizer.CurrentLanguage);
        statusMessage = Localizer["settings.localizationExported"];
    }

    private async Task HandleImportLocalizationAsync(InputFileChangeEventArgs args)
    {
        var json = await ReadFileAsync(args.File);
        await Localizer.ImportLanguageAsync(json);
        statusMessage = Localizer["settings.localizationImported"];
    }

    private async Task HandleLanguageChangedAsync(string languageCode)
    {
        await Localizer.SetLanguageAsync(languageCode);
        statusMessage = Localizer["settings.languageUpdated"];
    }

    private async Task HandleCurrencyChangedAsync(string currencyCode)
    {
        await AppState.SetCurrencyAsync(currencyCode);
