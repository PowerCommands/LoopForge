    private static string GetUsedStorageColor(long usedBytes)
    {
        var usedMegabytes = usedBytes / 1024d / 1024d;

        if (usedMegabytes >= 8d)
        {
            return "#E53935";
        }

        if (usedMegabytes >= 5d)
        {
            return "#FFB300";
        }

        return "#1565C0";
    }

    private static string FormatStorageMb(long bytes)
    {
        var megabytes = bytes / 1024d / 1024d;
        return $"{megabytes:0.00} MB";
    }

    private void ToggleApplicationDataSection(string key)
    {
        var isExpanded = ExpandedApplicationDataSections.TryGetValue(key, out var current) && current;
        ExpandedApplicationDataSections[key] = !isExpanded;
        RebuildApplicationDataSections();
    }

    private void RebuildApplicationDataSections()
    {
        var sections = new List<ApplicationDataSection>();
        AddApplicationDataSections(sections, AppState.Data, typeof(ApplicationData), "ApplicationData", "ApplicationData", isRoot: true);

        ApplicationDataSections = sections;
    }

    private void AddApplicationDataSections(List<ApplicationDataSection> sections, object? value, Type type, string key, string name, bool isRoot = false)
    {
        var properties = GetInspectableProperties(type);
        var scalarProperties = properties.Where(property => IsSimpleType(property.PropertyType)).ToList();

        if (isRoot)
        {
            if (scalarProperties.Count > 0)
            {
                sections.Add(new ApplicationDataSection(
                    key,
                    name,
                    scalarProperties.Select(property => property.Name).ToList(),
                    [
                        new ApplicationDataRow(scalarProperties.Select(property => FormatPropertyValue(property.GetValue(value))).ToList())
                    ],
                    IsSectionExpanded(key)));
            }
        }
        else if (TryGetCollectionElementType(type, out _))
        {
            var elementType = GetCollectionElementType(type);
            var columns = GetInspectableProperties(elementType).Select(column => column.Name).ToList();
            var rows = (value as System.Collections.IEnumerable)?.Cast<object>()
                .Select(item => new ApplicationDataRow(GetInspectableProperties(elementType).Select(column => FormatPropertyValue(column.GetValue(item))).ToList()))
                .ToList() ?? [];

            sections.Add(new ApplicationDataSection(key, name, columns, rows, IsSectionExpanded(key)));
        }
        else
        {
            var columns = properties.Select(property => property.Name).ToList();
            var rows = value is null
                ? new List<ApplicationDataRow>()
                : new List<ApplicationDataRow> { new(properties.Select(property => FormatPropertyValue(property.GetValue(value))).ToList()) };

            sections.Add(new ApplicationDataSection(key, name, columns, rows, IsSectionExpanded(key)));
        }

        if (isRoot)
        {
            foreach (var property in properties.Where(property => !IsSimpleType(property.PropertyType)))
            {
                var propertyValue = property.GetValue(value);
                AddApplicationDataSections(sections, propertyValue, property.PropertyType, property.Name, property.Name);
            }

            return;
        }

        var childType = TryGetCollectionElementType(type, out var collectionElementType)
            ? collectionElementType
            : type;

        foreach (var property in GetInspectableProperties(childType).Where(property => !IsSimpleType(property.PropertyType)))
        {
            var childKey = $"{key}/{property.Name}";
            var childName = $"{name}/{property.Name}";
            AddApplicationDataSections(sections, null, property.PropertyType, childKey, childName);
        }
    }

    private bool IsSectionExpanded(string key) =>
        ExpandedApplicationDataSections.TryGetValue(key, out var isExpanded) && isExpanded;

    private static IReadOnlyList<PropertyInfo> GetInspectableProperties(Type type) =>
        type.GetProperties(BindingFlags.Public | BindingFlags.Instance)
            .Where(property => property.CanRead && property.GetIndexParameters().Length == 0)
            .OrderBy(property => property.MetadataToken)
            .ToList();

    private static bool TryGetCollectionElementType(Type type, out Type elementType)
    {
        elementType = null!;
        if (type == typeof(string))
        {
            return false;
        }

        if (type.IsArray)
        {
            elementType = type.GetElementType()!;
            return true;
        }

        if (!type.IsGenericType)
        {
            return false;
        }

        var genericDefinition = type.GetGenericTypeDefinition();
        if (genericDefinition != typeof(List<>) && genericDefinition != typeof(IReadOnlyList<>))
        {
            return false;
        }

        elementType = type.GetGenericArguments()[0];
        return true;
    }

    private static Type GetCollectionElementType(Type type)
    {
        _ = TryGetCollectionElementType(type, out var elementType);
        return elementType;
    }

    private string FormatPropertyValue(object? value)
    {
        if (value is null)
        {
            return string.Empty;
        }

        return value switch
        {
            DateOnly date => date.ToString("yyyy-MM-dd"),
            DateTime dateTime => dateTime.ToString("yyyy-MM-dd HH:mm:ss"),
            DateTimeOffset dateTimeOffset => dateTimeOffset.ToString("yyyy-MM-dd HH:mm:ss zzz"),
            bool boolean => boolean ? "true" : "false",
            IFormattable formattable when value is not Enum => formattable.ToString(null, System.Globalization.CultureInfo.InvariantCulture),
            _ when IsSimpleType(value.GetType()) => value.ToString() ?? string.Empty,
            _ => LocalStorageService.Serialize(value)
        };
    }

    private static bool IsSimpleType(Type type)
    {
        var targetType = Nullable.GetUnderlyingType(type) ?? type;

        return targetType.IsPrimitive ||
               targetType.IsEnum ||
               targetType == typeof(string) ||
               targetType == typeof(decimal) ||
               targetType == typeof(Guid) ||
               targetType == typeof(DateOnly) ||
               targetType == typeof(DateTime) ||
               targetType == typeof(DateTimeOffset) ||
               targetType == typeof(TimeOnly) ||
               targetType == typeof(TimeSpan);
    }

    public void Dispose()
    {
        Localizer.Changed -= HandleChanged;
        AppState.Changed -= HandleChanged;
        ApplicationLogService.Changed -= HandleChanged;
        SyncService.Changed -= HandleChanged;
    }

    private sealed record ManagedLocalStorageFile(string Key, string Description);

    private sealed record LocalStorageFileRow(string Key, string Description, int RecordCount, bool Exists);

    private sealed record ApplicationDataSection(string Key, string Name, IReadOnlyList<string> Columns, IReadOnlyList<ApplicationDataRow> Rows, bool IsExpanded)
    {
        public int RowCount => Rows.Count;
    }

    private sealed record ApplicationDataRow(IReadOnlyList<string> Cells);
