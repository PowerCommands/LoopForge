        if (SyncService.Metadata.LatestResult is not null &&
            latestSyncResult?.TimestampUtc != SyncService.Metadata.LatestResult.TimestampUtc)
        {
            latestSyncResult = SyncService.Metadata.LatestResult;
        }
    }

