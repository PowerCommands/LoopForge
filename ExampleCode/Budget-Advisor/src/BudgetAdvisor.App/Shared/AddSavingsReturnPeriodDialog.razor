@using System.ComponentModel.DataAnnotations
@inject LocalizationService Localizer

<MudDialog>
    <DialogContent>
        <EditForm EditContext="editContext" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid mt-3">
                <div>
                    <label class="form-label">@Localizer["field.start"]</label>
                    <InputDate class="form-control" @bind-Value="model.StartDate" />
                    <ValidationMessage For="() => model.StartDate" />
                </div>
                <div>
                    <label class="form-label">@Localizer["field.end"]</label>
                    <InputDate class="form-control" @bind-Value="model.EndDate" />
                    <ValidationMessage For="() => model.EndDate" />
                </div>
                <div>
                    <label class="form-label">@Localizer[AccountType == SavingsAccountType.Bank ? "savings.interestRate" : "savings.estimatedReturn"]</label>
                    <InputNumber class="form-control" @bind-Value="model.RatePercent" />
                    <ValidationMessage For="() => model.RatePercent" />
                </div>
                @if (AccountType == SavingsAccountType.Bank)
                {
                    <div>
                        <label class="form-label">@Localizer["savings.taxPercent"]</label>
                        <InputNumber class="form-control" @bind-Value="model.TaxPercent" />
                        <ValidationMessage For="() => model.TaxPercent" />
                    </div>
                }
            </div>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Localizer["action.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">@Localizer["savings.addPeriod"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public SavingsAccountType AccountType { get; set; }

    private AddSavingsReturnPeriodDialogModel model = new();
    private EditContext editContext = default!;

    protected override void OnInitialized()
    {
        model.StartDate = DateTime.Today;
        model.EndDate = DateTime.Today;
        editContext = new EditContext(model);
    }

    private void Submit()
    {
        if (!editContext.Validate())
        {
            return;
        }

        HandleSubmit();
    }

    private void HandleSubmit() => MudDialog.Close(DialogResult.Ok(model));

    private void Cancel() => MudDialog.Cancel();

    public sealed class AddSavingsReturnPeriodDialogModel
    {
        [Required(ErrorMessage = "Start date is required.")]
        public DateTime? StartDate { get; set; }

        [Required(ErrorMessage = "End date is required.")]
        public DateTime? EndDate { get; set; }

        [Range(typeof(decimal), "-999999999", "999999999", ErrorMessage = "Rate is out of range.")]
        public decimal RatePercent { get; set; }

        [Range(typeof(decimal), "0.0000", "100", ErrorMessage = "Tax percent must be between 0 and 100.")]
        public decimal TaxPercent { get; set; }
    }
}
