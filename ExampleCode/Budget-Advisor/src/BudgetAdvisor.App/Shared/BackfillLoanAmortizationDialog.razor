@using System.ComponentModel.DataAnnotations
@inject LocalizationService Localizer

<MudDialog>
    <DialogContent>
        <MudText Class="mt-1">@Localizer["loans.backfillNotice"]</MudText>

        <EditForm EditContext="editContext" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid mt-3">
                <div>
                    <label class="form-label">@Localizer["field.start"]</label>
                    <InputDate class="form-control" @bind-Value="model.StartDate" />
                    <ValidationMessage For="() => model.StartDate" />
                </div>
                <div>
                    <label class="form-label">@Localizer["field.end"]</label>
                    <InputDate class="form-control" @bind-Value="model.EndDate" />
                    <ValidationMessage For="() => model.EndDate" />
                </div>
                <div>
                    <label class="form-label">@Localizer["housing.monthlyAmortizationAmount"]</label>
                    <InputNumber class="form-control" @bind-Value="model.MonthlyAmortizationAmount" />
                    <ValidationMessage For="() => model.MonthlyAmortizationAmount" />
                </div>
                <div>
                    <label class="form-label">@Localizer["loans.monthlyInterestAmount"]</label>
                    <InputNumber class="form-control" @bind-Value="model.MonthlyInterestAmount" />
                    <ValidationMessage For="() => model.MonthlyInterestAmount" />
                </div>
            </div>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Localizer["action.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">@Localizer["loans.backfillSubmit"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public decimal InitialAmortizationAmount { get; set; }

    [Parameter]
    public decimal InitialInterestAmount { get; set; }

    private BackfillLoanAmortizationDialogModel model = new();
    private EditContext editContext = default!;

    protected override void OnInitialized()
    {
        var currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        model.StartDate = currentMonth;
        model.EndDate = currentMonth;
        model.MonthlyAmortizationAmount = InitialAmortizationAmount;
        model.MonthlyInterestAmount = InitialInterestAmount;
        editContext = new EditContext(model);
    }

    private void Submit()
    {
        if (!editContext.Validate())
        {
            return;
        }

        HandleSubmit();
    }

    private void HandleSubmit() => MudDialog.Close(DialogResult.Ok(model));

    private void Cancel() => MudDialog.Cancel();

    public sealed class BackfillLoanAmortizationDialogModel : IValidatableObject
    {
        [Required(ErrorMessage = "Start date is required.")]
        public DateTime? StartDate { get; set; }

        [Required(ErrorMessage = "End date is required.")]
        public DateTime? EndDate { get; set; }

        [Range(typeof(decimal), "0.00", "999999999", ErrorMessage = "Monthly amortization amount must be zero or greater.")]
        public decimal MonthlyAmortizationAmount { get; set; }

        [Range(typeof(decimal), "0.00", "999999999", ErrorMessage = "Monthly interest amount must be zero or greater.")]
        public decimal MonthlyInterestAmount { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (StartDate.HasValue && EndDate.HasValue && EndDate.Value.Date < StartDate.Value.Date)
            {
                yield return new ValidationResult("End date must be the same as or later than start date.", [nameof(EndDate)]);
            }

            if (MonthlyAmortizationAmount <= 0m && MonthlyInterestAmount <= 0m)
            {
                yield return new ValidationResult("At least one monthly amount must be greater than zero.", [nameof(MonthlyAmortizationAmount), nameof(MonthlyInterestAmount)]);
            }
        }
    }
}
