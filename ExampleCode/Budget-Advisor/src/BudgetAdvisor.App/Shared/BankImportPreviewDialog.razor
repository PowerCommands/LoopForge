@using System.ComponentModel.DataAnnotations
@using System.Text
@using BudgetAdvisor.App.Imports
@using BudgetAdvisor.Domain.Enums
@using BudgetAdvisor.Domain.Models
@inject IDialogService DialogService
@inject LocalizationService Localizer
@inject ApplicationState AppState
@inject TransactionImportService ImportService

<MudDialog Class="bank-import-preview-dialog">
    <DialogContent>
        @if (!string.IsNullOrWhiteSpace(ProviderLogoPath))
        {
            <div class="mb-3">
                <img src="@ProviderLogoPath" alt="@ProviderDisplayName" class="bank-import-provider-logo" />
            </div>
        }

        <MudText Typo="Typo.h6">@Localizer["expenses.import.previewTitle"]</MudText>
        @if (!string.IsNullOrWhiteSpace(ProviderDisplayName))
        {
            <MudText Typo="Typo.body2" Class="mb-3">@string.Format(Localizer["expenses.import.previewHelp"], ProviderDisplayName)</MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mb-3">@Localizer["expenses.import.loadingFile"]</MudText>
        }

        @if (IsBusy)
        {
            <div class="bank-import-progress-header mb-3">
                <MudProgressLinear Value="@ProgressValue"
                                   Color="Color.Primary"
                                   Rounded="true"
                                   Size="Size.Large" />
                <div class="d-flex justify-content-between align-items-center mt-2">
                    <MudText Typo="Typo.body2">@ProgressText</MudText>
                    <MudText Typo="Typo.body2">@($"{ProgressValue:0}%")</MudText>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(validationMessage))
        {
            <div class="status-banner mb-3">@validationMessage</div>
        }

        @if (HasImportedMatches)
        {
            <div class="status-banner mb-3 bank-import-filter-banner">
                @if (!showAllRows)
                {
                    <span>@Localizer["expenses.import.filteredFromDate"]</span>
                }

                <div class="form-check mb-0">
                    <InputCheckbox class="form-check-input"
                                   @bind-Value="showAllRows"
                                   @bind-Value:after="HandleShowAllRowsChanged"
                                   disabled="@IsBusy" />
                    <label class="form-check-label">@Localizer["filter.showAll"]</label>
                </div>
            </div>
        }

        <div class="form-grid mb-3">
            <div>
                <label class="form-label">@Localizer["field.description"]</label>
                <InputText class="form-control" @bind-Value="descriptionFilter" @bind-Value:after="HandleDescriptionFilterChanged" disabled="@IsBusy" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="table app-table">
                <thead>
                    <tr>
                        <th>
                            <InputCheckbox @bind-Value="selectAllRows"
                                           @bind-Value:after="HandleSelectAllRowsChanged"
                                           disabled="@(IsBusy || FilteredRows.Count == 0)" />
                        </th>
                        <th>@Localizer["field.description"]</th>
                        <th>
                            <div class="table-actions-header">
                                <span>@Localizer["field.hide"]</span>
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                               title="@Localizer["expenses.import.showAllHiddenRows"]"
                                               aria-label="@Localizer["expenses.import.showAllHiddenRows"]"
                                               Size="Size.Small"
                                               OnClick="ShowAllHiddenRows"
                                               Disabled="@IsBusy" />
                            </div>
                        </th>
                        <th>@Localizer["field.date"]</th>
                        <th>@Localizer["field.amount"]</th>
                        <th>@Localizer["field.category"]</th>
                        <th>@Localizer["field.subcategory"]</th>
                        <th>
                            <div class="table-actions-header">
                                <span>@Localizer["field.use"]</span>
                                <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep"
                                               title="@Localizer["expenses.import.clearApplyHistory"]"
                                               aria-label="@Localizer["expenses.import.clearApplyHistory"]"
                                               Size="Size.Small"
                                               OnClick="ClearApplyHistoryAsync"
                                               Disabled="@(IsBusy || !HasApplySuggestionHistory)" />
                            </div>
                        </th>
                        <th>@Localizer["expenses.import.recurring"]</th>
                        <th>@Localizer["field.start"]</th>
                        <th>@Localizer["field.endDate"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredRows.Count == 0)
                    {
                        <tr>
                            <td colspan="11">@Localizer["expenses.import.noRowsAfterFilters"]</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in FilteredRows)
                        {
                            <tr class="@(row.IsLeaving ? "bank-import-row-leaving" : string.Empty)">
                                <td>
                                    <InputCheckbox @bind-Value="row.Include"
                                                   @bind-Value:after="() => HandleRowIncludeChanged(row)"
                                                   disabled="@(IsBusy || row.IsHandledAsSavingsDeposit)" />
                                </td>
                                <td>
                                    <div class="d-flex flex-column gap-2">
                                        <span>@row.Description</span>
                                        @if (row.IsHandledAsSavingsDeposit)
                                        {
                                            <span class="chip bank-import-status-chip">@Localizer["expenseCategory.Savings"]</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <MudIconButton Icon="@Icons.Material.Filled.VisibilityOff"
                                                   title="@Localizer["expenses.import.hideMatchingRows"]"
                                                   aria-label="@Localizer["expenses.import.hideMatchingRows"]"
                                                   Size="Size.Small"
                                                   OnClick="@(() => HideMatchingRows(row))"
                                                   Disabled="@(IsBusy || row.IsHandledAsSavingsDeposit)" />
                                </td>
                                <td>@row.TransactionDate.ToString("yyyy-MM-dd")</td>
                                <td>@AppState.FormatCurrency(row.Amount)</td>
                                <td>
                                    <InputSelect class="form-select"
                                                 @bind-Value="row.MainCategoryValue"
                                                 @bind-Value:after="() => HandleMainCategoryChanged(row)"
                                                 disabled="@(IsBusy || row.IsHandledAsSavingsDeposit)">
                                        @foreach (var category in GetMainCategoryOptions(row))
                                        {
                                            <option value="@category">@GetMainCategoryLabel(category)</option>
                                        }
                                    </InputSelect>
                                </td>
                                <td>
                                    <InputText class="form-control"
                                               @bind-Value="row.Subcategory"
                                               @bind-Value:after="() => HandleSubcategoryChanged(row)"
                                               list="@GetSubcategoryListId(row)"
                                               disabled="@(IsBusy || row.IsHandledAsSavingsDeposit || row.IsSavingsCategory)" />
                                    <datalist id="@GetSubcategoryListId(row)">
                                        @foreach (var suggestion in GetSubcategorySuggestions(row))
                                        {
                                            <option value="@suggestion"></option>
                                        }
                                    </datalist>
                                </td>
                                <td>
                                    <div class="button-row">
                                        @foreach (var suggestion in GetApplySuggestions(row))
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-secondary btn-sm bank-import-apply-button"
                                                    @onclick="() => ApplySuggestion(row, suggestion)"
                                                    disabled="@(IsBusy || row.IsHandledAsSavingsDeposit)">
                                                @GetSuggestionLabel(suggestion)
                                            </button>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <InputCheckbox @bind-Value="row.IsRecurring" disabled="@(IsBusy || row.IsHandledAsSavingsDeposit || row.IsSavingsCategory)" />
                                </td>
                                <td>
                                    <InputDate class="form-control"
                                               @bind-Value="row.StartDate"
                                               disabled="@(!row.IsRecurring || IsBusy || row.IsHandledAsSavingsDeposit || row.IsSavingsCategory)" />
                                </td>
                                <td>
                                    <InputDate class="form-control"
                                               @bind-Value="row.EndDate"
                                               disabled="@(!row.IsRecurring || IsBusy || row.IsHandledAsSavingsDeposit || row.IsSavingsCategory)" />
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (isImporting && importStatuses.Count > 0)
        {
            <div class="bank-import-status-list mt-3">
                @foreach (var status in importStatuses)
                {
                    <div class="bank-import-status-item">@status</div>
                }
            </div>
        }
    </DialogContent>
    <DialogActions>
        <div class="bank-import-dialog-actions">
            <div class="bank-import-member-select">
                <label class="form-label mb-1">@Localizer["field.member"]</label>
                <InputSelect class="form-select"
                             @bind-Value="selectedMemberId"
                             disabled="@IsBusy">
                    <option value="">@Localizer["expenses.import.noMember"]</option>
                    @foreach (var member in AppState.Data.Members.OrderBy(member => member.Name))
                    {
                        <option value="@member.Id">@member.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="button-row">
                <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="@IsBusy">@Localizer["action.cancel"]</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync" Disabled="@IsBusy">@Localizer["action.import"]</MudButton>
            </div>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .bank-import-preview-dialog .mud-dialog {
        max-width: 1480px;
        width: min(1480px, calc(100vw - 24px));
        min-height: min(860px, calc(100vh - 24px));
        max-height: calc(100vh - 24px);
    }

    .bank-import-preview-dialog .mud-dialog-content {
        overflow-y: auto;
    }

    .bank-import-filter-banner {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .bank-import-apply-button {
        white-space: nowrap;
    }

    .bank-import-dialog-actions {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .bank-import-member-select {
        min-width: min(18rem, 100%);
    }

    @@media (max-width: 899px) {
        .bank-import-preview-dialog .mud-dialog {
            width: calc(100vw - 16px);
            min-height: calc(100vh - 16px);
            max-height: calc(100vh - 16px);
        }
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string ProviderDisplayName { get; set; } = string.Empty;

    [Parameter]
    public string ProviderLogoPath { get; set; } = string.Empty;

    [Parameter]
    public TransactionImportFile ImportFile { get; set; } = new();

    private static IReadOnlyList<SubcategoryMainCategory> MainCategories { get; } =
    [
        SubcategoryMainCategory.Income,
        SubcategoryMainCategory.Food,
        SubcategoryMainCategory.Housing,
        SubcategoryMainCategory.Transport,
        SubcategoryMainCategory.Clothing,
        SubcategoryMainCategory.Other
    ];
    private static IReadOnlyList<string> StandardMainCategoryValues { get; } =
        MainCategories.Select(category => category.ToString()).ToList();
    private static IReadOnlyList<string> MainCategoryValuesWithSavings { get; } =
        StandardMainCategoryValues.Concat([SavingsMainCategoryValue]).ToList();
    private const int RenderBatchSize = 25;
    private const string SavingsMainCategoryValue = "__Savings__";

    private readonly List<ImportPreviewRowModel> rows = [];
    private readonly List<string> importStatuses = [];
    private readonly HashSet<string> hiddenDescriptions = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<TransactionMatchKey, List<ExistingTransactionMatch>> incomeMatchIndex = [];
    private readonly Dictionary<TransactionMatchKey, List<ExistingTransactionMatch>> expenseMatchIndex = [];
    private readonly Dictionary<TransactionOccurrenceKey, int> importOccurrenceCounters = [];
    private List<ImportedTransactionCandidate> transactions = [];
    private string? validationMessage;
    private string descriptionFilter = string.Empty;
    private bool selectAllRows = true;
    private bool isPreparing = true;
    private bool isImporting;
    private bool hasStartedPreparing;
    private bool showAllRows;
    private bool showSavedHiddenRows;
    private int preparedCount;
    private int totalTransactionCount;
    private int totalSelectedCount;
    private int importedCount;
    private Guid? selectedMemberId;

    private bool HasApplySuggestionHistory => AppState.TransactionImportData.ImportedExpenseCategorySuggestions.Count > 0;
    private bool HasImportedMatches => rows.Any(row => row.IsAlreadyImported);
    private bool IsBusy => isPreparing || isImporting;
    private string ProgressText =>
        isPreparing
            ? string.Format(Localizer["expenses.import.preparing"], preparedCount, totalTransactionCount)
            : string.Format(Localizer["expenses.import.progress"], importedCount, totalSelectedCount);

    private double ProgressValue =>
        (isPreparing ? totalTransactionCount : totalSelectedCount) == 0
            ? 0
            : (isPreparing ? preparedCount : importedCount) * 100d / (isPreparing ? totalTransactionCount : totalSelectedCount);

    private IReadOnlyList<ImportPreviewRowModel> FilteredRows =>
        rows
            .Where(row =>
                string.IsNullOrWhiteSpace(descriptionFilter) ||
                row.Description.Contains(descriptionFilter.Trim(), StringComparison.OrdinalIgnoreCase))
            .Where(row => showAllRows || !row.IsAlreadyImported)
            .Where(row => !hiddenDescriptions.Contains(GetDescriptionKey(row.Description)))
            .Where(row => showAllRows || showSavedHiddenRows || !MatchesSavedHideSuggestion(row.Description))
            .ToList();

    protected override void OnInitialized()
    {
        BuildExistingTransactionIndexes();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || hasStartedPreparing)
        {
            return;
        }

        hasStartedPreparing = true;
        await PrepareRowsAsync();
    }

    private async Task SubmitAsync()
    {
        validationMessage = null;

        var selectedRows = rows.Where(row => row.Include).ToList();
        if (selectedRows.Count == 0)
        {
            validationMessage = Localizer["expenses.import.validation.noRowsSelected"];
            return;
        }

        if (selectedRows.Any(row => string.IsNullOrWhiteSpace(row.Subcategory)))
        {
            validationMessage = Localizer["expenses.import.validation.subcategoryRequired"];
            return;
        }

        if (selectedRows.Any(row => row.IsExpense && row.IsRecurring && !row.EndDate.HasValue))
        {
            validationMessage = Localizer["expenses.import.validation.endDateRequired"];
            return;
        }

        if (selectedRows.Any(row => row.IsExpense && row.IsRecurring && !row.StartDate.HasValue))
        {
            validationMessage = Localizer["expenses.import.validation.startDateRequired"];
            return;
        }

        if (selectedRows.Any(row => row.IsExpense && row.IsRecurring && row.EndDate.HasValue && DateOnly.FromDateTime(row.EndDate.Value) < row.TransactionDate))
        {
            validationMessage = Localizer["expenses.import.validation.endDateBeforeTransaction"];
            return;
        }

        if (selectedRows.Any(row => row.IsExpense && row.IsRecurring && row.StartDate.HasValue && row.EndDate.HasValue && DateOnly.FromDateTime(row.EndDate.Value) < DateOnly.FromDateTime(row.StartDate.Value)))
        {
            validationMessage = Localizer["expenses.import.validation.endDateBeforeStartDate"];
            return;
        }

        var importedSuggestions = selectedRows
            .Where(row => row.IsExpense)
            .Where(row => !string.IsNullOrWhiteSpace(row.Subcategory))
            .Select(row => new ImportedExpenseCategorySuggestion
            {
                Description = row.Description,
                Category = MapMainCategoryToExpenseCategory(row.MainCategory),
                Subcategory = row.Subcategory,
                MatchType = ImportSuggestionMatchType.Exact,
                Action = ImportSuggestionAction.ApplySuggestion
            })
            .ToList();

        var importId = Guid.NewGuid();
        rows.RemoveAll(row => !row.Include);
        selectAllRows = false;
        isImporting = true;
        totalSelectedCount = selectedRows.Count;
        importedCount = 0;
        importStatuses.Clear();
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        foreach (var row in selectedRows)
        {
            var draft = new ImportedTransactionDraft
            {
                MemberId = selectedMemberId,
                Date = row.TransactionDate,
                StartDate = row.StartDate.HasValue ? DateOnly.FromDateTime(row.StartDate.Value) : null,
                EndDate = row.EndDate.HasValue ? DateOnly.FromDateTime(row.EndDate.Value) : null,
                SignedAmount = row.Amount,
                IsRecurring = row.IsRecurring,
                ImportId = importId,
                ImportOccurrence = row.ImportOccurrence,
                MainCategory = row.MainCategory,
                Subcategory = row.Subcategory.Trim(),
                Description = row.Description
            };

            await AppState.ImportTransactionAsync(draft);

            importedCount++;
            importStatuses.Insert(0, string.Format(Localizer["expenses.import.rowImported"], row.Description, row.TransactionDate.ToString("yyyy-MM-dd")));
            rows.Remove(row);

            if (ShouldRefreshUi(importedCount, totalSelectedCount))
            {
                await InvokeAsync(StateHasChanged);
                await Task.Yield();
            }
        }

        await AppState.RecordTransactionImportBatchAsync(importId, importedCount, selectedMemberId);
        await AppState.SaveImportedExpenseCategorySuggestionsAsync(importedSuggestions);
        MudDialog.Close(DialogResult.Ok(importedCount));
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task PrepareRowsAsync()
    {
        rows.Clear();
        importStatuses.Clear();
        importOccurrenceCounters.Clear();
        preparedCount = 0;
        isPreparing = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var detectedImport = ImportService.Parse(ImportFile);
            ProviderDisplayName = detectedImport.DisplayName;
            ProviderLogoPath = detectedImport.LogoPath;
            transactions = detectedImport.Candidates.ToList();
            totalTransactionCount = transactions.Count;

            if (transactions.Count == 0)
            {
                validationMessage = Localizer["expenses.import.noTransactions"];
                isPreparing = false;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }
        catch (TransactionImportException exception)
        {
            validationMessage = exception.Message;
            isPreparing = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        foreach (var transaction in transactions)
        {
            rows.Add(CreateRow(transaction, GetNextImportOccurrence(transaction)));
            preparedCount++;
            importStatuses.Insert(0, string.Format(Localizer["expenses.import.rowPrepared"], transaction.Description, transaction.TransactionDate.ToString("yyyy-MM-dd")));

            if (ShouldRefreshUi(preparedCount, totalTransactionCount))
            {
                RefreshSelectAllRows();
                await InvokeAsync(StateHasChanged);
            }
        }

        isPreparing = false;
        RefreshSelectAllRows();
        await InvokeAsync(StateHasChanged);
    }

    private Task HandleSelectAllRowsChanged()
    {
        foreach (var row in FilteredRows)
        {
            if (row.IsHandledAsSavingsDeposit)
            {
                continue;
            }

            row.Include = selectAllRows;
        }

        return InvokeAsync(StateHasChanged);
    }

    private Task HandleRowIncludeChanged(ImportPreviewRowModel row)
    {
        _ = row;
        RefreshSelectAllRows();
        return InvokeAsync(StateHasChanged);
    }

    private Task HandleDescriptionFilterChanged()
    {
        RefreshSelectAllRows();
        return InvokeAsync(StateHasChanged);
    }

    private Task HandleShowAllRowsChanged()
    {
        RefreshSelectAllRows();
        return InvokeAsync(StateHasChanged);
    }

    private Task HideMatchingRows(ImportPreviewRowModel row)
    {
        showSavedHiddenRows = false;
        hiddenDescriptions.Add(GetDescriptionKey(row.Description));
        RefreshSelectAllRows();
        return InvokeAsync(StateHasChanged);
    }

    private Task ShowAllHiddenRows()
    {
        showSavedHiddenRows = true;
        hiddenDescriptions.Clear();
        RefreshSelectAllRows();
        return InvokeAsync(StateHasChanged);
    }

    private async Task ClearApplyHistoryAsync()
    {
        await AppState.ClearImportedExpenseCategorySuggestionsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ApplySuggestion(ImportPreviewRowModel row, ApplyCategorySuggestion suggestion)
    {
        row.MainCategoryValue = suggestion.MainCategory.ToString();
        row.Subcategory = suggestion.Subcategory;
        if (!row.IsExpense)
        {
            row.IsRecurring = false;
            row.StartDate = null;
            row.EndDate = null;
        }

        row.Include = true;
        RefreshSelectAllRows();
    }

    private async Task HandleMainCategoryChanged(ImportPreviewRowModel row)
    {
        if (row.IsSavingsCategory)
        {
            if (row.Amount >= 0m)
            {
                row.MainCategoryValue = SubcategoryMainCategory.Other.ToString();
                await InvokeAsync(StateHasChanged);
                return;
            }

            var parameters = new DialogParameters<RegisterSavingsDepositDialog>
            {
                { dialog => dialog.PresetAmount, Math.Abs(row.Amount) },
                { dialog => dialog.PresetDate, row.TransactionDate.ToDateTime(TimeOnly.MinValue) }
            };

            var dialog = await DialogService.ShowAsync<RegisterSavingsDepositDialog>(Localizer["savings.deposit"], parameters);
            if (dialog is null)
            {
                row.MainCategoryValue = SubcategoryMainCategory.Other.ToString();
                await InvokeAsync(StateHasChanged);
                return;
            }

            var result = await dialog.Result;
            if (result?.Canceled ?? true)
            {
                row.MainCategoryValue = SubcategoryMainCategory.Other.ToString();
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (result.Data is not SavingsAmountDialogModel savingsModel ||
                !savingsModel.Date.HasValue ||
                !savingsModel.SavingsAccountId.HasValue)
            {
                row.MainCategoryValue = SubcategoryMainCategory.Other.ToString();
                await InvokeAsync(StateHasChanged);
                return;
            }

            await AppState.AddSavingsDepositAsync(
                savingsModel.SavingsAccountId.Value,
                DateOnly.FromDateTime(savingsModel.Date.Value),
                savingsModel.Amount,
                savingsModel.IsAdjustment);

            row.IsHandledAsSavingsDeposit = true;
            row.Include = false;
            row.IsRecurring = false;
            row.StartDate = null;
            row.EndDate = null;
            row.Subcategory = string.Empty;
            RefreshSelectAllRows();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!row.IsExpense)
        {
            row.IsRecurring = false;
            row.StartDate = null;
            row.EndDate = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private Task HandleSubcategoryChanged(ImportPreviewRowModel row)
    {
        if (!row.Include && !string.IsNullOrWhiteSpace(row.Subcategory))
        {
            row.Include = true;
            RefreshSelectAllRows();
        }

        return InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<ApplyCategorySuggestion> GetApplySuggestions(ImportPreviewRowModel row)
    {
        if (row.Include || row.IsHandledAsSavingsDeposit || row.IsSavingsCategory)
        {
            return [];
        }

        return rows
            .Where(candidate => candidate.Id != row.Id)
            .Where(candidate => !candidate.IsHandledAsSavingsDeposit)
            .Where(candidate => candidate.Include)
            .Where(candidate => !string.IsNullOrWhiteSpace(candidate.Subcategory))
            .Where(candidate => string.Equals(GetDescriptionKey(candidate.Description), GetDescriptionKey(row.Description), StringComparison.OrdinalIgnoreCase))
            .Select(candidate => new ApplyCategorySuggestion(candidate.MainCategory, candidate.Subcategory.Trim()))
            .Concat(
                AppState.TransactionImportData.ImportedExpenseCategorySuggestions
                    .Where(_ => row.IsExpense)
                    .Where(candidate => candidate.Action == ImportSuggestionAction.ApplySuggestion)
                    .Where(candidate => SuggestionMatchesDescription(candidate, row.Description))
                    .Select(candidate => new ApplyCategorySuggestion(MapExpenseCategoryToMainCategory(candidate.Category), candidate.Subcategory.Trim())))
            .Distinct()
            .OrderBy(candidate => candidate.MainCategory)
            .ThenBy(candidate => candidate.Subcategory, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private string GetSuggestionLabel(ApplyCategorySuggestion suggestion) =>
        $"{GetMainCategoryLabel(suggestion.MainCategory)} / {suggestion.Subcategory}";

    private void RefreshSelectAllRows()
    {
        var selectableRows = FilteredRows
            .Where(row => !row.IsHandledAsSavingsDeposit)
            .ToList();

        selectAllRows = selectableRows.Count > 0 && selectableRows.All(row => row.Include);
    }

    private IReadOnlyList<string> GetMainCategoryOptions(ImportPreviewRowModel row) =>
        row.Amount < 0m
            ? MainCategoryValuesWithSavings
            : StandardMainCategoryValues;

    private static string GetSubcategoryListId(ImportPreviewRowModel row) => $"bank-import-subcategory-{row.Id}";

    private static string GetDescriptionKey(string description) =>
        string.IsNullOrWhiteSpace(description)
            ? string.Empty
            : description.Trim().Normalize(NormalizationForm.FormKC);

    private bool MatchesSavedHideSuggestion(string description) =>
        AppState.TransactionImportData.ImportedExpenseCategorySuggestions
            .Where(suggestion => suggestion.Action == ImportSuggestionAction.HideRow)
            .Any(suggestion => SuggestionMatchesDescription(suggestion, description));

    private static bool SuggestionMatchesDescription(ImportedExpenseCategorySuggestion suggestion, string description)
    {
        var suggestionKey = GetDescriptionKey(suggestion.Description);
        var descriptionKey = GetDescriptionKey(description);

        if (string.IsNullOrWhiteSpace(suggestionKey) || string.IsNullOrWhiteSpace(descriptionKey))
        {
            return false;
        }

        return suggestion.MatchType == ImportSuggestionMatchType.Contains
            ? descriptionKey.Contains(suggestionKey, StringComparison.OrdinalIgnoreCase)
            : string.Equals(descriptionKey, suggestionKey, StringComparison.OrdinalIgnoreCase);
    }

    private void BuildExistingTransactionIndexes()
    {
        incomeMatchIndex.Clear();
        expenseMatchIndex.Clear();

        foreach (var income in AppState.Data.IncomeRecords)
        {
            if (!income.TransactionDate.HasValue)
            {
                continue;
            }

            var key = CreateMatchKey(GetIncomeEntryMatchName(income), income.TransactionDate.Value, income.Amount, income.ImportOccurrence ?? 1);
            AddExistingMatch(incomeMatchIndex, key, new ExistingTransactionMatch(income.Id, SubcategoryMainCategory.Income, income.Type));
        }

        foreach (var expense in AppState.Data.ExpenseRecords)
        {
            if (!expense.TransactionDate.HasValue)
            {
                continue;
            }

            var expenseMatchName = string.IsNullOrWhiteSpace(expense.Description)
                ? AppState.GetExpenseDescriptionDisplay(expense)
                : expense.Description.Trim();

            var key = CreateMatchKey(expenseMatchName, expense.TransactionDate.Value, expense.Amount, expense.ImportOccurrence ?? 1);
            AddExistingMatch(expenseMatchIndex, key, new ExistingTransactionMatch(expense.Id, MapExpenseCategoryToMainCategory(expense.Category), expense.Subcategory));
        }
    }

    private ImportPreviewRowModel CreateRow(ImportedTransactionCandidate transaction, int importOccurrence)
    {
        var match = GetExistingMatch(transaction, importOccurrence);

        return new ImportPreviewRowModel
        {
            Include = false,
            Description = transaction.Description,
            TransactionDate = transaction.TransactionDate,
            StartDate = transaction.Amount < 0m ? transaction.TransactionDate.ToDateTime(TimeOnly.MinValue) : null,
            Amount = transaction.Amount,
            ImportOccurrence = importOccurrence,
            MainCategoryValue = (match?.MainCategory ?? (transaction.Amount > 0m ? SubcategoryMainCategory.Income : SubcategoryMainCategory.Other)).ToString(),
            Subcategory = match?.Subcategory ?? string.Empty,
            IsAlreadyImported = match is not null
        };
    }

    private ExistingTransactionMatch? GetExistingMatch(ImportedTransactionCandidate transaction, int importOccurrence)
    {
        var index = transaction.Amount > 0m ? incomeMatchIndex : expenseMatchIndex;
        var key = CreateMatchKey(transaction.Description, transaction.TransactionDate, Math.Abs(transaction.Amount), importOccurrence);

        if (!index.TryGetValue(key, out var matches))
        {
            return null;
        }

        return matches.Count == 1
            ? matches[0]
            : null;
    }

    private static TransactionMatchKey CreateMatchKey(string description, DateOnly date, decimal amount, int importOccurrence) =>
        new(GetDescriptionKey(description), date, amount, importOccurrence);

    private int GetNextImportOccurrence(ImportedTransactionCandidate transaction)
    {
        var key = new TransactionOccurrenceKey(
            GetDescriptionKey(transaction.Description),
            transaction.TransactionDate,
            Math.Abs(transaction.Amount),
            transaction.Amount > 0m);

        var nextOccurrence = importOccurrenceCounters.TryGetValue(key, out var currentOccurrence)
            ? currentOccurrence + 1
            : 1;

        importOccurrenceCounters[key] = nextOccurrence;
        return nextOccurrence;
    }

    private static void AddExistingMatch(Dictionary<TransactionMatchKey, List<ExistingTransactionMatch>> index, TransactionMatchKey key, ExistingTransactionMatch match)
    {
        if (!index.TryGetValue(key, out var matches))
        {
            matches = [];
            index[key] = matches;
        }

        matches.Add(match);
    }

    private static string GetIncomeEntryMatchName(IncomeEntry entry) =>
        string.IsNullOrWhiteSpace(entry.Metadata)
            ? entry.Type.Trim()
            : entry.Metadata.Trim();

    private static bool ShouldRefreshUi(int processedCount, int totalCount) =>
        processedCount > 0 &&
        (processedCount % RenderBatchSize == 0 || processedCount == totalCount);

    private IReadOnlyList<string> GetSubcategorySuggestions(ImportPreviewRowModel row) =>
        row.IsSavingsCategory
            ? []
            : row.MainCategory == SubcategoryMainCategory.Income
            ? AppState.GetIncomeTypeSuggestions()
            : AppState.GetExpenseSubcategorySuggestions(MapMainCategoryToExpenseCategory(row.MainCategory));

    private string GetMainCategoryLabel(string mainCategoryValue) =>
        string.Equals(mainCategoryValue, SavingsMainCategoryValue, StringComparison.Ordinal)
            ? Localizer["expenseCategory.Savings"]
            : GetMainCategoryLabel(Enum.TryParse<SubcategoryMainCategory>(mainCategoryValue, out var parsed) ? parsed : SubcategoryMainCategory.Other);

    private string GetMainCategoryLabel(SubcategoryMainCategory mainCategory) => mainCategory switch
    {
        SubcategoryMainCategory.Income => Localizer["subcategoryMainCategory.Income"],
        _ => Localizer[$"expenseCategory.{MapMainCategoryToExpenseCategory(mainCategory)}"]
    };

    private static ExpenseCategory MapMainCategoryToExpenseCategory(SubcategoryMainCategory mainCategory) => mainCategory switch
    {
        SubcategoryMainCategory.Food => ExpenseCategory.Food,
        SubcategoryMainCategory.Housing => ExpenseCategory.Housing,
        SubcategoryMainCategory.Transport => ExpenseCategory.Transport,
        SubcategoryMainCategory.Clothing => ExpenseCategory.Clothing,
        _ => ExpenseCategory.Other
    };

    private static SubcategoryMainCategory MapExpenseCategoryToMainCategory(ExpenseCategory category) => category switch
    {
        ExpenseCategory.Food => SubcategoryMainCategory.Food,
        ExpenseCategory.Housing => SubcategoryMainCategory.Housing,
        ExpenseCategory.Transport => SubcategoryMainCategory.Transport,
        ExpenseCategory.Clothing => SubcategoryMainCategory.Clothing,
        _ => SubcategoryMainCategory.Other
    };

    private sealed class ImportPreviewRowModel
    {
        public Guid Id { get; set; } = Guid.NewGuid();

        public bool Include { get; set; }

        public string Description { get; set; } = string.Empty;

        public DateOnly TransactionDate { get; set; }

        public decimal Amount { get; set; }

        public int ImportOccurrence { get; set; } = 1;

        public bool IsAlreadyImported { get; set; }

        public bool IsRecurring { get; set; }

        public DateTime? StartDate { get; set; }

        public DateTime? EndDate { get; set; }

        public bool IsLeaving { get; set; }

        public string MainCategoryValue { get; set; } = SubcategoryMainCategory.Other.ToString();

        public string Subcategory { get; set; } = string.Empty;

        public bool IsHandledAsSavingsDeposit { get; set; }

        public bool IsSavingsCategory => string.Equals(MainCategoryValue, SavingsMainCategoryValue, StringComparison.Ordinal);

        public SubcategoryMainCategory MainCategory =>
            Enum.TryParse<SubcategoryMainCategory>(MainCategoryValue, out var parsed)
                ? parsed
                : SubcategoryMainCategory.Other;

        public bool IsExpense => !IsSavingsCategory && MainCategory != SubcategoryMainCategory.Income;
    }

    private sealed record ApplyCategorySuggestion(SubcategoryMainCategory MainCategory, string Subcategory);

    private sealed record ExistingTransactionMatch(Guid EntryId, SubcategoryMainCategory MainCategory, string Subcategory);

    private readonly record struct TransactionOccurrenceKey(string Description, DateOnly Date, decimal Amount, bool IsIncome);

    private readonly record struct TransactionMatchKey(string Description, DateOnly Date, decimal Amount, int ImportOccurrence);
}
