@using System.ComponentModel.DataAnnotations
@inject LocalizationService Localizer

<MudDialog>
    <DialogContent>
        <EditForm EditContext="editContext" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid mt-3">
                <div>
                    <label class="form-label">@Localizer["field.name"]</label>
                    <InputText class="form-control" @bind-Value="model.Name" />
                    <ValidationMessage For="() => model.Name" />
                </div>
                <div>
                    <label class="form-label">@Localizer["credits.provider"]</label>
                    <InputText class="form-control" @bind-Value="model.Provider" />
                    <ValidationMessage For="() => model.Provider" />
                </div>
                <div>
                    <label class="form-label">@Localizer["credits.startDate"]</label>
                    <InputDate class="form-control" @bind-Value="model.StartDate" />
                    <ValidationMessage For="() => model.StartDate" />
                </div>
                <div>
                    <label class="form-label">@Localizer["credits.creditLimit"]</label>
                    <InputNumber class="form-control" @bind-Value="model.CreditLimit" />
                    <ValidationMessage For="() => model.CreditLimit" />
                </div>
                <div>
                    <label class="form-label">@Localizer["credits.remainingDebt"]</label>
                    <InputNumber class="form-control" @bind-Value="model.RemainingDebt" />
                    <ValidationMessage For="() => model.RemainingDebt" />
                </div>
                <div>
                    <label class="form-label">@Localizer["credits.monthlyInterestRate"]</label>
                    <InputNumber class="form-control" @bind-Value="model.MonthlyInterestRate" />
                    <ValidationMessage For="() => model.MonthlyInterestRate" />
                </div>
            </div>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Localizer["action.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">@Localizer["action.create"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private CreateCreditDialogModel model = new();
    private EditContext editContext = default!;

    protected override void OnInitialized()
    {
        model.StartDate = DateTime.Today;
        editContext = new EditContext(model);
    }

    private void Submit()
    {
        if (!editContext.Validate())
        {
            return;
        }

        HandleSubmit();
    }

    private void HandleSubmit() => MudDialog.Close(DialogResult.Ok(model));

    private void Cancel() => MudDialog.Cancel();

    public sealed class CreateCreditDialogModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(100, ErrorMessage = "Name must be 100 characters or fewer.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Provider is required.")]
        [StringLength(100, ErrorMessage = "Provider must be 100 characters or fewer.")]
        public string Provider { get; set; } = string.Empty;

        [Required(ErrorMessage = "Start date is required.")]
        public DateTime? StartDate { get; set; }

        [Range(typeof(decimal), "0.00", "999999999", ErrorMessage = "Credit limit must not be negative.")]
        public decimal CreditLimit { get; set; }

        [Range(typeof(decimal), "0.00", "999999999", ErrorMessage = "Remaining debt must not be negative.")]
        public decimal RemainingDebt { get; set; }

        [Range(typeof(decimal), "0.00", "999999999", ErrorMessage = "Annual interest rate must not be negative.")]
        public decimal MonthlyInterestRate { get; set; }

        public bool ResetAtEndOfMonth { get; set; }
    }
}
