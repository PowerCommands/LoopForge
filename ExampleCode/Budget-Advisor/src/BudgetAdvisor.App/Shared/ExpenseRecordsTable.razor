@inject ApplicationState AppState
@inject LocalizationService Localizer
@inject LocalStorageService LocalStorage

<section class="card-panel mt-4">
    @if (ShowTitle || ShowAllCostsToggle)
    {
        <div class="section-title-row">
            @if (ShowTitle)
            {
                <h2>@Localizer[TitleKey]</h2>
            }

            @if (ShowAllCostsToggle)
            {
                <div class="d-flex align-items-center gap-3 flex-wrap w-100">
                    <label class="form-check-label d-flex align-items-center gap-2">
                        <InputCheckbox class="form-check-input mt-0" Value="IncludeAllCosts" ValueChanged="HandleIncludeAllCostsChanged" ValueExpression="() => IncludeAllCosts" />
                        <span>@Localizer["filter.showAllCosts"]</span>
                    </label>
                    @if (OnDeleteFiltered.HasDelegate)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.DeleteSweep"
                                   Class="ms-auto"
                                   Disabled="@(FilteredEntries.Count == 0)"
                                   OnClick="HandleDeleteFilteredAsync">
                            @Localizer["action.deleteAll"]
                        </MudButton>
                    }
                </div>
            }
        </div>
    }

    <div class="form-grid mb-3">
        <div>
            <label class="form-label">@Localizer["filter.name"]</label>
            <InputText class="form-control" @bind-Value="filter.Name" />
        </div>
        @if (ShowCategoryFilter)
        {
            <div>
                <label class="form-label">@Localizer["field.category"]</label>
                <InputSelect class="form-select" @bind-Value="filter.CategoryFilter">
                    <option value="">@Localizer["filter.allCategories"]</option>
                    @foreach (var option in CategoryOptions)
                    {
                        <option value="@option.Value">@Localizer[$"expenseCategory.{option.Category}"]</option>
                    }
                </InputSelect>
            </div>
        }
        <div>
            <label class="form-label">@Localizer["field.subcategory"]</label>
            <InputSelect class="form-select" @bind-Value="filter.SubcategoryFilter">
                <option value="">@Localizer["filter.allSubcategories"]</option>
                @foreach (var option in SubcategoryOptions)
                {
                    <option value="@option">@option</option>
                }
            </InputSelect>
        </div>
        <div>
            <label class="form-label">@Localizer["filter.startDate"]</label>
            <InputDate class="form-control" @bind-Value="filter.StartDate" @bind-Value:after="PersistDateFiltersAsync" />
        </div>
        <div>
            <label class="form-label">@Localizer["filter.endDate"]</label>
            <InputDate class="form-control" @bind-Value="filter.EndDate" @bind-Value:after="PersistDateFiltersAsync" />
        </div>
    </div>

    <div class="table-responsive">
        <table class="table app-table">
            <thead>
                <tr>
                    <th>@Localizer["field.name"]</th>
                    <th>@Localizer["field.category"]</th>
                    <th>@Localizer["table.period"]</th>
                    <th>@Localizer["field.amount"]</th>
                    @if (OnDelete.HasDelegate)
                    {
                        <th>@Localizer["field.actions"]</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (!FilteredEntries.Any())
                {
                    <tr>
                        <td colspan="@GetColumnCount()" class="empty-state">@Localizer["table.noCostRows"]</td>
                    </tr>
                }
                else
                {
                    @foreach (var entry in FilteredEntries)
                    {
                        <tr>
                            <td>@GetEntryName(entry)</td>
                            <td>@GetEntryCategoryLabel(entry)</td>
                            <td>@FormatPeriod(entry)</td>
                            <td>@AppState.FormatCurrency(entry.Amount)</td>
                            @if (OnDelete.HasDelegate)
                            {
                                <td>
                                    <div class="button-row expense-action-row">
                                        @if (ShowTransportVehicleActions)
                                        {
                                            @foreach (var vehicle in TransportVehicles)
                                            {
                                                <button class="btn btn-outline-primary btn-sm vehicle-tag-button"
                                                        title="@vehicle.Name"
                                                        disabled="@(entry.TransportVehicleId == vehicle.Id)"
                                                        @onclick="() => HandleAssignTransportVehicleAsync(entry, vehicle.Id)">
                                                    @GetVehicleButtonLabel(vehicle.Name)
                                                </button>
                                            }
                                        }

                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="@(() => OnDelete.InvokeAsync(entry))" />
                                    </div>
                                </td>
                            }
                        </tr>
                    }

                    <tr class="table-summary-row">
                        <td colspan="3" class="table-summary-label">@Localizer["table.sum"]</td>
                        <td class="table-summary-value">@AppState.FormatCurrency(FilteredTotal)</td>
                        @if (OnDelete.HasDelegate)
                        {
                            <td></td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@code {
    private readonly ExpenseTableFilter filter = new();
    private ExpenseQueryScope lastResolvedScope;
    private bool defaultDateRangeApplied;
    private bool pendingDateFilterLoad = true;
    private string currentDateFilterStorageKey = string.Empty;

    [Parameter]
    public ExpenseQueryScope Scope { get; set; }

    [Parameter]
    public string TitleKey { get; set; } = "table.costRows";

    [Parameter]
    public bool ShowTitle { get; set; } = true;

    [Parameter]
    public bool ShowAllCostsToggle { get; set; }

    [Parameter]
    public bool IncludeAllCosts { get; set; }

    [Parameter]
    public EventCallback<bool> IncludeAllCostsChanged { get; set; }

    [Parameter]
    public EventCallback<ExpenseEntry> OnDelete { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyList<ExpenseEntry>> OnDeleteFiltered { get; set; }

    [Parameter]
    public bool DefaultToCurrentMonth { get; set; }

    [Parameter]
    public bool ShowCategoryFilter { get; set; } = true;

    [Parameter]
    public bool UseScopedDateRangeForShowAllCosts { get; set; }

    private IReadOnlyList<ExpenseEntry> FilteredEntries => AppState.GetFilteredExpenseEntries(filter);
    private decimal FilteredTotal => FilteredEntries.Sum(entry => entry.Amount);
    private bool ShowTransportVehicleActions => Scope == ExpenseQueryScope.Transport && TransportVehicles.Count > 0;

    private IReadOnlyList<ExpenseFilterCategoryOption> CategoryOptions => AppState.GetExpenseFilterCategoryOptions(filter);
    private IReadOnlyList<string> SubcategoryOptions => AppState.GetExpenseFilterSubcategoryOptions(filter);
    private IReadOnlyList<TransportVehicle> TransportVehicles =>
        AppState.Data.TransportVehicles
            .OrderBy(vehicle => vehicle.Name)
            .ToList();

    protected override void OnParametersSet()
    {
        var resolvedScope = ResolveScope();
        if (resolvedScope != lastResolvedScope)
        {
            filter.CategoryFilter = string.Empty;
            filter.SubcategoryFilter = string.Empty;
            lastResolvedScope = resolvedScope;
        }

        filter.Scope = resolvedScope;
        var dateFilterStorageKey = GetDateFilterStorageKey(resolvedScope);
        if (!string.Equals(dateFilterStorageKey, currentDateFilterStorageKey, StringComparison.Ordinal))
        {
            currentDateFilterStorageKey = dateFilterStorageKey;
            pendingDateFilterLoad = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!pendingDateFilterLoad)
        {
            return;
        }

        pendingDateFilterLoad = false;
        await LoadPersistedDateFiltersAsync();
        ApplyDefaultDateRange();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleIncludeAllCostsChanged(bool includeAllCosts)
    {
        filter.CategoryFilter = string.Empty;
        filter.SubcategoryFilter = string.Empty;
        IncludeAllCosts = includeAllCosts;

        if (UseScopedDateRangeForShowAllCosts)
        {
            ApplyShowAllDateRange(includeAllCosts);
            await PersistDateFiltersAsync();
        }

        await IncludeAllCostsChanged.InvokeAsync(includeAllCosts);
    }

    private async Task HandleDeleteFilteredAsync()
    {
        if (!OnDeleteFiltered.HasDelegate || FilteredEntries.Count == 0)
        {
            return;
        }

        await OnDeleteFiltered.InvokeAsync(FilteredEntries.ToList());
    }

    private ExpenseQueryScope ResolveScope() =>
        ShowAllCostsToggle && IncludeAllCosts && !UseScopedDateRangeForShowAllCosts
            ? ExpenseQueryScope.All
            : Scope;

    private void ApplyDefaultDateRange()
    {
        if (UseScopedDateRangeForShowAllCosts && IncludeAllCosts)
        {
            ApplyShowAllDateRange(true);
            defaultDateRangeApplied = true;
            return;
        }

        if (!DefaultToCurrentMonth || defaultDateRangeApplied || filter.StartDate.HasValue || filter.EndDate.HasValue)
        {
            return;
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var currentMonth = new DateOnly(today.Year, today.Month, 1);
        filter.StartDate = currentMonth;
        filter.EndDate = currentMonth;
        defaultDateRangeApplied = true;
    }

    private void ApplyShowAllDateRange(bool includeAllCosts)
    {
        if (!includeAllCosts)
        {
            if (DefaultToCurrentMonth)
            {
                var today = DateOnly.FromDateTime(DateTime.Today);
                var currentMonth = new DateOnly(today.Year, today.Month, 1);
                filter.StartDate = currentMonth;
                filter.EndDate = currentMonth;
            }

            return;
        }

        var scopeFilter = new ExpenseTableFilter { Scope = Scope };
        var scopedEntries = AppState.GetFilteredExpenseEntries(scopeFilter);
        if (scopedEntries.Count == 0)
        {
            filter.StartDate = null;
            filter.EndDate = null;
            return;
        }

        var orderedEntries = scopedEntries
            .Select(entry => new DateOnly(entry.Year, entry.Month, 1))
            .OrderBy(date => date)
            .ToList();

        filter.StartDate = orderedEntries.First();
        filter.EndDate = orderedEntries.Last();
    }

    private async Task LoadPersistedDateFiltersAsync()
    {
        var persistedFilter = await LocalStorage.LoadAsync<PersistedExpenseDateFilter>(currentDateFilterStorageKey);
        filter.StartDate = persistedFilter?.StartDate;
        filter.EndDate = persistedFilter?.EndDate;
        defaultDateRangeApplied = filter.StartDate.HasValue || filter.EndDate.HasValue;
    }

    private async Task PersistDateFiltersAsync()
    {
        await LocalStorage.SaveAsync(currentDateFilterStorageKey, new PersistedExpenseDateFilter
        {
            StartDate = filter.StartDate,
            EndDate = filter.EndDate
        });
    }

    private static string GetDateFilterStorageKey(ExpenseQueryScope scope) => $"budget-advisor.expense-records.date-filter.{scope}";

    private string GetEntryName(ExpenseEntry entry) => AppState.GetExpenseDescriptionDisplay(entry);

    private string GetEntryCategoryLabel(ExpenseEntry entry) => $"{Localizer[$"expenseCategory.{entry.Category}"]} / {AppState.GetExpenseSubcategoryDisplay(entry)}";

    private static string FormatPeriod(ExpenseEntry entry) => $"{entry.Year:0000}/{entry.Month:00}";

    private async Task HandleAssignTransportVehicleAsync(ExpenseEntry entry, Guid vehicleId)
    {
        await AppState.UpdateExpenseTransportVehicleAsync(entry.Id, vehicleId);
    }

    private static string GetVehicleButtonLabel(string name)
    {
        var trimmedName = name?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(trimmedName))
        {
            return "???";
        }

        return trimmedName.Length <= 6
            ? trimmedName
            : trimmedName[..6];
    }

    private int GetColumnCount() => OnDelete.HasDelegate ? 5 : 4;

    private sealed class PersistedExpenseDateFilter
    {
        public DateOnly? StartDate { get; set; }

        public DateOnly? EndDate { get; set; }
    }
}

<style>
    .expense-action-row {
        flex-wrap: wrap;
    }

    .vehicle-tag-button {
        min-width: 4.5rem;
    }
</style>
