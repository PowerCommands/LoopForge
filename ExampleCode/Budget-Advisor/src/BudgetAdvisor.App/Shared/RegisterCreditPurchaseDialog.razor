@using System.ComponentModel.DataAnnotations
@inject LocalizationService Localizer

<MudDialog>
    <DialogContent>
        <EditForm EditContext="editContext" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid mt-3">
                <div>
                    <label class="form-label">@Localizer["field.description"]</label>
                    <InputText class="form-control" @bind-Value="model.Description" />
                    <ValidationMessage For="() => model.Description" />
                </div>
                <div>
                    <label class="form-label">@Localizer["field.mainCategory"]</label>
                    <InputSelect class="form-select" @bind-Value="model.Category">
                        @foreach (var category in Categories)
                        {
                            <option value="@category">@Localizer[$"expenseCategory.{category}"]</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => model.Category" />
                </div>
                <div>
                    <label class="form-label">@Localizer["field.subcategory"]</label>
                    <InputText class="form-control" @bind-Value="model.Subcategory" list="credit-purchase-subcategories" />
                    <datalist id="credit-purchase-subcategories">
                        @foreach (var subcategory in SubcategorySuggestions)
                        {
                            <option value="@subcategory"></option>
                        }
                    </datalist>
                    <ValidationMessage For="() => model.Subcategory" />
                </div>
                <div>
                    <label class="form-label">@Localizer["credits.purchaseAmount"]</label>
                    <InputNumber class="form-control" @bind-Value="model.Amount" />
                    <ValidationMessage For="() => model.Amount" />
                </div>
                <div>
                    <label class="form-label">@Localizer["credits.purchaseDate"]</label>
                    <InputDate class="form-control" @bind-Value="model.Date" />
                    <ValidationMessage For="() => model.Date" />
                </div>
            </div>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Localizer["action.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">@Localizer["credits.registerPurchase"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<ExpenseCategory> Categories { get; set; } = [];

    [Parameter]
    public IReadOnlyList<string> SubcategorySuggestions { get; set; } = [];

    private RegisterCreditPurchaseDialogModel model = new();
    private EditContext editContext = default!;

    protected override void OnInitialized()
    {
        model.Date = DateTime.Today;
        editContext = new EditContext(model);
    }

    private void Submit()
    {
        if (!editContext.Validate())
        {
            return;
        }

        HandleSubmit();
    }

    private void HandleSubmit() => MudDialog.Close(DialogResult.Ok(model));

    private void Cancel() => MudDialog.Cancel();

    public sealed class RegisterCreditPurchaseDialogModel
    {
        [Required(ErrorMessage = "Description is required.")]
        [StringLength(100, ErrorMessage = "Description must be 100 characters or fewer.")]
        public string Description { get; set; } = string.Empty;

        [Required(ErrorMessage = "Date is required.")]
        public DateTime? Date { get; set; }

        public ExpenseCategory Category { get; set; } = ExpenseCategory.Other;

        [Range(typeof(decimal), "0.01", "999999999", ErrorMessage = "Purchase amount must be greater than zero.")]
        public decimal Amount { get; set; }

        [Required(ErrorMessage = "Subcategory is required.")]
        [StringLength(60, ErrorMessage = "Subcategory must be 60 characters or fewer.")]
        public string Subcategory { get; set; } = string.Empty;
    }
}
