@using System.ComponentModel.DataAnnotations
@using BudgetAdvisor.Domain.Models
@inject ApplicationState AppState
@inject LocalizationService Localizer

<MudDialog>
    <DialogContent>
        <EditForm EditContext="editContext" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid mt-3">
                <div>
                    <label class="form-label">@Localizer["closeMonth.account"]</label>
                    <InputSelect class="form-select"
                                 @bind-Value="model.SavingsAccountId"
                                 disabled="@IsAccountSelectionDisabled">
                        <option value="">@Localizer["savings.selectAccount"]</option>
                        @foreach (var account in SavingsAccounts)
                        {
                            <option value="@account.Id">@account.AccountName</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => model.SavingsAccountId" />
                </div>
                <div>
                    <label class="form-label">@Localizer["field.date"]</label>
                    <InputDate class="form-control" @bind-Value="model.Date" disabled="@IsDateDisabled" />
                    <ValidationMessage For="() => model.Date" />
                </div>
                <div>
                    <label class="form-label">@Localizer["field.amount"]</label>
                    <InputNumber class="form-control" @bind-Value="model.Amount" disabled="@IsAmountDisabled" />
                    <ValidationMessage For="() => model.Amount" />
                </div>
            </div>

            <div class="form-check mt-3">
                <InputCheckbox class="form-check-input" @bind-Value="model.IsAdjustment" disabled="@IsAdjustmentDisabled" />
                <label class="form-check-label">@Localizer["savings.adjustment"]</label>
            </div>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Localizer["action.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">@Localizer["savings.deposit"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid? SavingsAccountId { get; set; }

    [Parameter]
    public decimal? PresetAmount { get; set; }

    [Parameter]
    public DateTime? PresetDate { get; set; }

    private SavingsAmountDialogModel model = new();
    private EditContext editContext = default!;

    private IReadOnlyList<SavingsAccount> SavingsAccounts =>
        AppState.Data.SavingsAccounts
            .OrderBy(account => account.AccountName)
            .ToList();

    private bool IsAccountSelectionDisabled => SavingsAccountId.HasValue;
    private bool IsAmountDisabled => PresetAmount.HasValue;
    private bool IsDateDisabled => PresetDate.HasValue;
    private bool IsAdjustmentDisabled => PresetAmount.HasValue;

    protected override void OnInitialized()
    {
        model.SavingsAccountId = SavingsAccountId;
        model.Date = PresetDate ?? DateTime.Today;
        model.Amount = PresetAmount ?? 0m;
        if (PresetAmount.HasValue)
        {
            model.IsAdjustment = false;
        }

        editContext = new EditContext(model);
    }

    private void Submit()
    {
        if (!editContext.Validate())
        {
            return;
        }

        HandleSubmit();
    }

    private void HandleSubmit() => MudDialog.Close(DialogResult.Ok(model));

    private void Cancel() => MudDialog.Cancel();
}
