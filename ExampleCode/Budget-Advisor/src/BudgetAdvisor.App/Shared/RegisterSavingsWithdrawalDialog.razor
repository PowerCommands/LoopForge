@using System.ComponentModel.DataAnnotations
@inject LocalizationService Localizer

<MudDialog>
    <DialogContent>
        <EditForm EditContext="editContext" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid mt-3">
                <div>
                    <label class="form-label">@Localizer["field.date"]</label>
                    <InputDate class="form-control" @bind-Value="model.Date" />
                    <ValidationMessage For="() => model.Date" />
                </div>
                <div>
                    <label class="form-label">@Localizer["field.amount"]</label>
                    <InputNumber class="form-control" @bind-Value="model.Amount" />
                    <ValidationMessage For="() => model.Amount" />
                </div>
            </div>

            <div class="form-check mt-3">
                <InputCheckbox class="form-check-input" @bind-Value="model.IsAdjustment" />
                <label class="form-check-label">@Localizer["savings.adjustment"]</label>
            </div>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Localizer["action.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">@Localizer["savings.withdrawal"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private SavingsAmountDialogModel model = new();
    private EditContext editContext = default!;

    protected override void OnInitialized()
    {
        model.Date = DateTime.Today;
        editContext = new EditContext(model);
    }

    private void Submit()
    {
        if (!editContext.Validate())
        {
            return;
        }

        HandleSubmit();
    }

    private void HandleSubmit() => MudDialog.Close(DialogResult.Ok(model));

    private void Cancel() => MudDialog.Cancel();
}
